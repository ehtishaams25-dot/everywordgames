---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="Contact Us | EveryWordGames"
  description="Contact EveryWordGames for feedback, game suggestions, partnerships, and support."
  path="/contact"
>
  <section class="section">
    <div class="container seo-copy">
      <p class="eyebrow">Contact</p>
      <h1>Contact EveryWordGames</h1>
      <p class="lede">Have feedback, a game idea, or a bug report? We use player feedback to improve the game library, hint quality, difficulty balance, and overall experience.</p>
      <p>Email: <a class="pill" href="mailto:support@everywordgames.com">support@everywordgames.com</a></p>
      <p>For the fastest report, include the game name, the device or browser, and a short description of what happened.</p>
    </div>
  </section>
</SiteLayout>
