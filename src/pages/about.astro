---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="About EveryWordGames - Wordle, Guessing, and Puzzle Games"
  description="Learn about EveryWordGames, a fast local-first platform for Wordle variants, guessing games, word puzzles, stats, and achievements."
  path="/about"
>
  <section class="section">
    <div class="container seo-copy">
      <p class="eyebrow">About Us</p>
      <h1>About EveryWordGames</h1>
      <p class="lede">EveryWordGames is built for quick, repeatable play: Wordle variants, multi-board word games, geography guessing, entertainment clues, brand guessing, and classic word puzzles in one fast browser experience.</p>
      <p>Our goal is simple: make every round easy to start, easy to replay, and satisfying to track. Games save stats and achievements locally on your device, so players can build streaks and milestones without creating an account.</p>
      <p>The platform focuses on low-friction gameplay, clear color feedback, useful hints, replayable challenges, and a growing library of word and guessing games for casual daily play.</p>
    </div>
  </section>
</SiteLayout>
