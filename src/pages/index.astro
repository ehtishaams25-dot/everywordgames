---
import GameGrid from "@/components/GameGrid.astro";
import StatsPanel from "@/components/StatsPanel.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { categoryLabels, comingSoonGames, games, playableGames } from "@/data/games";

const featured = games.filter((game) => game.featured).slice(0, 8);

const categories = Object.entries(categoryLabels).filter(([key]) => key !== "future" && key !== "daily");
---

<SiteLayout path="/">


  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div class="hero-banner">
        <div class="hero-left">
          <div class="hero-badge">
            <span class="pulse-dot"></span>
            TODAY'S CHALLENGE
          </div>
          <h1 class="hero-title">
            DAILY<br /><span>WORD</span><br />GUESS
          </h1>
          <p class="hero-subtext">Solve today's puzzle to keep your streak alive — earn 50 XP and a special badge.</p>
          <div class="hero-actions">
            <a href="/wordle" class="btn-lime">▶ Play Now</a>
            <button class="btn-ghost">How to play</button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Top Games</h2>
          <p>The most popular puzzles right now.</p>
        </div>
      </div>
      <GameGrid games={featured} />
    </div>
  </section>



  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Jump Back In</h2>
          <p>Continue your recent games.</p>
        </div>
      </div>
      <div class="grid" id="recent-games"></div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Categories</h2>
          <p>Find your favorite type of puzzle.</p>
        </div>
      </div>
      <div class="categories-grid">
        {categories.map(([key, label]) => (
          <a class="category-card" href={key === "geography" || key === "entertainment" || key === "brands" ? "/guess" : (key === "wordle" || key === "multi-wordle") ? "/games/5-letter-wordle" : `/${key}`}>
            <span class="category-icon">{String(label).slice(0, 2).toUpperCase()}</span>
            <span class="category-name">{label}</span>
            <span class="category-count">{games.filter((game) => game.category === key).length} games</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Player Profile</h2>
          <p>Your stats, streaks, and unlocked badges.</p>
        </div>
      </div>
      <StatsPanel />
    </div>
  </section>
</SiteLayout>

<script>
  import { games } from "@/data/games";
  const recent = JSON.parse(localStorage.getItem("ewg:recent") ?? "[]") as string[];
  const root = document.querySelector("#recent-games");
  if (root) {
    const cards = recent
      .map((slug) => games.find((game) => game.slug === slug))
      .filter(Boolean)
      .map((game) => {
        let bannerUrl = "";
        if (game.slug === "hangman") bannerUrl = "/thumbnails/Hangman new.png";
        else if (game.slug === "guess-country") bannerUrl = "/thumbnails/guess country new.png";
        else if (game.slug === "guess-flag") bannerUrl = "/thumbnails/guess flag.png";
        else if (game.slug === "guess-capital") bannerUrl = "/thumbnails/guess capital.png";
        else if (game.slug === "guess-movie") bannerUrl = "/thumbnails/guess movie new.png";
        else if (game.slug === "guess-tv-show") bannerUrl = "/thumbnails/guess tv show.png";
        else if (game.slug === "guess-anime") bannerUrl = "/thumbnails/anime new.png";
        else if (game.slug === "antonym-challenge") bannerUrl = "/thumbnails/antonym.png";
        else if (game.slug === "missing-letters") bannerUrl = "/thumbnails/missing letters.png";
        else if (game.slug === "synonym-challenge") bannerUrl = "/thumbnails/synonym.png";
        else if (game.slug === "word-scramble") bannerUrl = "/thumbnails/word scramble.png";
        else if (game.category === "wordle" || game.category === "multi-wordle") bannerUrl = "/thumbnails/word guess new.png";
        else if (game.slug === "daily-wordle") bannerUrl = "/thumbnails/word guess new.png";
        else if (game.category === "geography") bannerUrl = "/thumbnails/geography category.png";
        else if (game.category === "entertainment") bannerUrl = "/thumbnails/movie category.png";
        else if (game.category === "brands") bannerUrl = "";
        else if (game.category === "word-games" || game.category === "daily") bannerUrl = "/thumbnails/word category.png";

        const initials = game.name.split(/\s+/).map((part) => part[0]).join("").slice(0, 2).toUpperCase();
        
        let bannerHtml = bannerUrl 
          ? `<img src="${bannerUrl}" alt="${game.name}" />`
          : `<span class="tile-icon" style="box-shadow: none;">${initials}</span>`;
          
        const tagHtml = game.daily ? `<span class="card-tag">DAILY</span>` : (game.comingSoon ? `<span class="card-tag" style="color: #FF7800; border-color: rgba(255,120,0,0.3); background: rgba(255,120,0,0.15);">SOON</span>` : "");

        return `
          <a class="game-card" href="/games/${game.slug}">
            <div class="card-banner" style="${!bannerUrl ? 'background: linear-gradient(135deg, #F4EFE6 0%, #EBE5DC 100%); display: grid; place-items: center;' : ''}">
              ${bannerHtml}
              ${tagHtml}
            </div>
            <div class="card-body">
              <span class="game-name">${game.name}</span>
              <span class="game-desc">${game.description}</span>
              <div class="play-btn">▶ Play</div>
            </div>
          </a>
        `;
      })
      .join("");
    root.innerHTML = cards || `<article class="stat"><strong>No recent games yet</strong><p class="muted">Play any mode and it will appear here.</p></article>`;
  }
</script>
