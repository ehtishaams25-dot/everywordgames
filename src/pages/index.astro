<!-- ═══════════════════════════════════════════════════════════════
     CLIENT-SIDE SCRIPTS
     ═══════════════════════════════════════════════════════════════ -->
<script>
  import { mountGame } from "@/lib/gameApp";
  import { loadStats, achievements } from "@/engines/playerStore";
  import { games } from "@/data/games";

  const root = document.querySelector<HTMLElement>("#game-root");
  const htpTemplates = document.querySelectorAll(".v2-htp-template");

  // Helper to switch game and HTP logic
  function switchGame(slug: string, engine: string) {
    if (root) {
      root.dataset.slug = slug;
      // Remount game (simulate loading state briefly for UX)
      root.innerHTML = `
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 400px; gap: 1rem;">
          <div class="v2-spinner"></div>
          <p class="muted" style="text-align: center; font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Loading Game...</p>
        </div>
      `;
      setTimeout(() => {
        mountGame(root);
      }, 50);
    }

    // Select is now handled inside gameApp.ts header

    // Toggle HTP visibility
    htpTemplates.forEach(t => {
      (t as HTMLElement).style.display = 'none';
      t.classList.remove('active');
    });

    // Map engines to HTP template IDs
    let targetHtpId = 'htp-word-guess';
    if (engine === 'guessing' || engine === 'countries' || engine === 'flags') {
      targetHtpId = 'htp-guessing';
    } else if (slug === 'word-scramble') {
      targetHtpId = 'htp-word-scramble';
    } else if (engine === 'word-puzzle' || engine === 'hangman' || engine === 'scramble') {
      targetHtpId = 'htp-word-puzzle';
    }

    const targetHtp = document.getElementById(targetHtpId);
    if (targetHtp) {
      targetHtp.style.display = 'block';
      targetHtp.classList.add('active');
    }
  }

  // 1. Initial Mount
  if (root) {
    setTimeout(() => {
      mountGame(root);
    }, 100);
  }

  // 2. SPA Dropdown Change Listener
  document.addEventListener("change", (e) => {
    const target = e.target as HTMLSelectElement;
    if (target && target.id === "spa-game-select") {
      const selectedOption = target.options[target.selectedIndex];
      const newSlug = selectedOption.value;
      const engine = selectedOption.getAttribute('data-engine') || 'word-guess';
      switchGame(newSlug, engine);
    }
  });

  // 3. Featured Card SPA Overrides
  // We want clicks on the feature cards to ALSO just swap the game instead of reloading
  const spaTriggers = document.querySelectorAll("[data-spa-trigger]");
  spaTriggers.forEach(trigger => {
    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      const newSlug = trigger.getAttribute("data-spa-trigger");
      if (newSlug) {
        // Find engine
        let engine = 'word-guess';
        const gameObj = games.find(g => g.slug === newSlug);
        if (gameObj) engine = gameObj.engine;
        switchGame(newSlug, engine);
        // Scroll to game
        document.querySelector('.v2-top-section')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // 4. Tab switching logic
  const tabs = document.querySelectorAll('.v2-tab-btn');
  const panels = document.querySelectorAll('.v2-tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Remove active from all
      tabs.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(p => p.classList.remove('active'));

      // Add active to clicked
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      
      const targetId = tab.getAttribute('data-target');
      const targetPanel = document.getElementById(targetId!);
      if (targetPanel) {
        targetPanel.classList.add('active');
      }
    });
  });

  // Also hijack game cards in the tabs so they swap instead of navigate
  const tabCards = document.querySelectorAll('.v2-tab-panel .game-card');
  tabCards.forEach(card => {
    card.addEventListener("click", (e) => {
      const href = card.getAttribute('href');
      // e.g. /games/guess-country/
      if (href && href.startsWith('/games/')) {
        e.preventDefault();
        const parts = href.split('/');
        const newSlug = parts[parts.length - 2] || parts[parts.length - 1]; // handle trailing slash
        
        let engine = 'word-guess';
        const gameObj = games.find(g => g.slug === newSlug);
        if (gameObj) engine = gameObj.engine;
        switchGame(newSlug, engine);
        // Scroll to game
        document.querySelector('.v2-top-section')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // 5. Player progress card
  function populateProgress() {
    if (typeof localStorage === "undefined") return;
    const stats = loadStats();
    const xp = stats.wins * 50 + stats.played * 10;
    const level = Math.floor(xp / 500) + 1;
    const progress = (xp % 500) / 500;
    const winRate = stats.played ? Math.round((stats.wins / stats.played) * 100) : 0;

    const ids: Record<string, string | number> = {
      "v2-stat-played": stats.played,
      "v2-stat-wins": stats.wins,
      "v2-stat-streak": stats.currentStreak,
      "v2-stat-rate": `${winRate}%`,
    };
    Object.entries(ids).forEach(([id, val]) => {
      const el = document.getElementById(id);
      if (el) el.textContent = String(val);
    });

    const circle = document.getElementById("v2-xp-circle") as SVGCircleElement | null;
    if (circle) {
      const circumference = 2 * Math.PI * 52;
      const offset = circumference * (1 - progress);
      circle.style.strokeDashoffset = String(offset);
    }

    const levelText = document.getElementById("v2-xp-level-text");
    if (levelText) levelText.textContent = String(level);

    const next = achievements.find((a) => !a.test(stats));
    if (next) {
      const nameEl = document.getElementById("v2-ach-name");
      const descEl = document.getElementById("v2-ach-desc");
      if (nameEl) nameEl.textContent = next.name;
      if (descEl) descEl.textContent = next.description;
    }
  }
  
  populateProgress();
  window.addEventListener("gamecompleted", populateProgress);
</script>
