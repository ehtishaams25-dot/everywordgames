---
import GameGrid from "@/components/GameGrid.astro";
import StatsPanel from "@/components/StatsPanel.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { categoryLabels, comingSoonGames, games, playableGames } from "@/data/games";

const featured = games.filter((game) => game.featured).slice(0, 8);
const trending = games.filter((game) => game.trending).slice(0, 8);
const categories = Object.entries(categoryLabels).filter(([key]) => key !== "future" && key !== "daily");
---

<SiteLayout path="/">


  <section class="section" style="padding-top: 2rem;">
    <div class="container">
      <div style="background: var(--primary); border-radius: 24px; padding: 3rem 2rem; display: flex; flex-direction: column; align-items: center; text-align: center; color: #0f172a; box-shadow: 0 12px 32px rgba(163, 230, 53, 0.2);">
        <span style="background: rgba(0,0,0,0.1); padding: 0.5rem 1rem; border-radius: 999px; font-weight: 900; margin-bottom: 1rem; letter-spacing: 1px;">★ TODAY'S CHALLENGE ★</span>
        <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 1rem; color: #0f172a; font-weight: 900;">Daily Word Guess</h1>
        <p style="font-size: 1.2rem; margin-bottom: 2rem; max-width: 500px; font-weight: 600;">Keep your streak alive! Solve today's puzzle to earn 50 XP and a special badge.</p>
        <a href="/wordle" class="button" style="background: #0f172a; color: var(--primary); padding: 1rem 2rem; font-size: 1.2rem; box-shadow: 0 6px 0 rgba(0,0,0,0.4);">Play Now</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Top Games</h2>
          <p>The most popular puzzles right now.</p>
        </div>
      </div>
      <GameGrid games={featured} />
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Trending Now</h2>
          <p>What everyone is playing today.</p>
        </div>
      </div>
      <GameGrid games={trending} />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Jump Back In</h2>
          <p>Continue your recent games.</p>
        </div>
      </div>
      <div class="grid" id="recent-games"></div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Categories</h2>
          <p>Find your favorite type of puzzle.</p>
        </div>
      </div>
      <div class="grid">
        {categories.map(([key, label]) => (
          <a class="game-card" href={key === "geography" || key === "entertainment" || key === "brands" ? "/guess" : `/${key}`}>
            <span class="tile-icon">{String(label).slice(0, 2).toUpperCase()}</span>
            <div class="card-copy">
              <h3 style="font-weight: 800;">{label}</h3>
              <p>{games.filter((game) => game.category === key).length} games</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <h2 style="font-weight: 800;">Player Profile</h2>
          <p>Your stats, streaks, and unlocked badges.</p>
        </div>
        <a class="button small secondary" href="/stats">View Profile</a>
      </div>
      <StatsPanel />
    </div>
  </section>
</SiteLayout>

<script>
  import { games } from "@/data/games";
  const recent = JSON.parse(localStorage.getItem("ewg:recent") ?? "[]") as string[];
  const root = document.querySelector("#recent-games");
  if (root) {
    const cards = recent
      .map((slug) => games.find((game) => game.slug === slug))
      .filter(Boolean)
      .map((game) => `<a class="game-card" href="/games/${game!.slug}"><span class="tile-icon">${game!.name.slice(0, 2).toUpperCase()}</span><div class="card-copy"><h3>${game!.name}</h3><p>${game!.description}</p></div><span class="status">Play again</span></a>`)
      .join("");
    root.innerHTML = cards || `<article class="stat"><strong>No recent games yet</strong><p class="muted">Play any mode and it will appear here.</p></article>`;
  }
</script>
