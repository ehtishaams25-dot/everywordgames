---
import SiteLayout from "@/layouts/SiteLayout.astro";
import GameCard from "@/components/GameCard.astro";
import { games, playableGames } from "@/data/games";


const categories = [
  { id: "geography", label: "GEOGRAPHY", games: games.filter((g) => g.category === "geography" && !g.comingSoon) },
  { id: "puzzles", label: "PUZZLES", games: games.filter((g) => g.category === "word-games" && !g.comingSoon) },
  { id: "multi-word", label: "MULTI-WORD", games: games.filter((g) => g.category === "multi-word-guess" && !g.comingSoon) },
];
---

<SiteLayout
  title="Play Free Online Word Games | Daily Puzzles & Geography Hub"
  description="Challenge your mind with the best free online word games! Play daily 5-letter word guesses, word scrambles, hangman, and guess the country geography trivia."
  path="/"
>

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the best free word games online?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you are looking for the best free word games online, EveryWordGames offers a massive library of daily challenges. You can play 5-letter guesses, classic hangman, and fun word games directly in your browser with absolutely no downloads required."
        }
      },
      {
        "@type": "Question",
        "name": "Are word games good for your brain?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! Engaging with daily vocabulary puzzles is a fantastic form of cognitive exercise. Regularly challenging your mind helps improve problem-solving abilities, enhances processing speed, and strengthens short-term memory."
        }
      },
      {
        "@type": "Question",
        "name": "Do word games help your brain prevent cognitive decline?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely. Scientific studies suggest that keeping the mind active with puzzles builds cognitive reserve. Playing free word games for adults regularly helps keep neural pathways active and sharpens your focus."
        }
      },
      {
        "@type": "Question",
        "name": "How to get better at word games?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The best strategy is consistent daily practice. Playing word games online free every day exposes you to new letter patterns, expands your vocabulary, and trains your brain to spot anagrams faster."
        }
      },
      {
        "@type": "Question",
        "name": "How do you play the guess the country game?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Our guess the country game section offers multiple ways to test your geography skills. You can play guess country by shape to identify a nation purely by its map outline, or try guess country by flag. We even have regional challenges like guess the country Europe!"
        }
      },
      {
        "@type": "Question",
        "name": "Are there sight word games for beginners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes! While we offer highly challenging puzzles for adults, games like our basic Word Scramble and Hangman serve as excellent, stress-free sight word games to help younger players recognize letter patterns and practice spelling."
        }
      }
    ]
  }
  </script>

  <!-- ═══════════════════════════════════════════════════════
       SECTION 1 — THE GAME & SPA DROPDOWN
       ═══════════════════════════════════════════════════════ -->
  <section class="v2-top-section">
    <div class="v2-top-layout container">
      <!-- Left Ad Placeholder -->
      <div class="v2-ad-placeholder left">
        <div class="v2-ad-inner"></div>
      </div>

      <!-- Center Game Container -->
      <div class="v2-game-core">
        

        <!-- The Game Mount Point -->
        <div id="game-root" data-slug="5-letter-word-guess">
          <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 400px; gap: 1rem;">
            <div class="v2-spinner"></div>
            <p class="muted" style="text-align: center; font-family: 'Bebas Neue', sans-serif; letter-spacing: 1px;">Loading Game...</p>
          </div>
        </div>
      </div>

      <!-- Right Ad Placeholder -->
      <div class="v2-ad-placeholder right">
        <div class="v2-ad-inner"></div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 2 — CATEGORIES TABS
       ═══════════════════════════════════════════════════════ -->
  <section class="v2-tabs-section">
    <div class="container">
      <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 2rem; gap: 1rem;">
        <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
        <h2 style="font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 2px; margin: 0; color: var(--text);">OTHER GAMES</h2>
        <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
      </div>
      <div class="v2-tabs" role="tablist">
        {categories.map((cat, i) => (
          <button 
            class={`v2-tab-btn ${i === 0 ? 'active' : ''}`} 
            role="tab" 
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${cat.id}`}
            id={`tab-${cat.id}`}
            data-target={`panel-${cat.id}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
      
      <div class="v2-tab-content-wrap">
        {categories.map((cat, i) => (
          <div 
            class={`v2-tab-panel grid ${i === 0 ? 'active' : ''}`} 
            id={`panel-${cat.id}`} 
            role="tabpanel" 
            aria-labelledby={`tab-${cat.id}`}
          >
            {cat.games.map(g => <GameCard game={g} />)}
            {cat.games.length === 0 && <p class="muted">More games coming soon!</p>}
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 4 — DYNAMIC HOW TO PLAY
       ═══════════════════════════════════════════════════════ -->
  <section class="v2-how-to-section">
    <div class="container">
      <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 3rem; gap: 1rem;">
        <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
        <h2 style="font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 2px; margin: 0; color: var(--text);">HOW TO PLAY</h2>
        <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
      </div>
      
      <!-- HTP: Word Guess Engine (Word Guess, Multi Word Guess) -->
      <div id="htp-word-guess" class="v2-htp-template active">
        <div class="v2-htp-grid">
          <div class="v2-htp-card">
            <div class="v2-htp-badge">1</div>
            <h3 class="v2-htp-title">Enter a word</h3>
            <p class="v2-htp-desc">Type in a word and press enter to start. You have a limited number of tries to guess the hidden word.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-typing">
                <span class="v2-tile">F</span>
                <span class="v2-tile">L</span>
                <span class="v2-tile">A</span>
                <span class="v2-tile">R</span>
                <span class="v2-tile">E</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">2</div>
            <h3 class="v2-htp-title">Use color clues</h3>
            <p class="v2-htp-desc">Green means correct. Yellow means right letter, wrong spot. Gray means it's not in the word.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-reveal">
                <span class="v2-tile v2-t-absent">F</span>
                <span class="v2-tile v2-t-absent">L</span>
                <span class="v2-tile v2-t-absent">A</span>
                <span class="v2-tile v2-t-present">R</span>
                <span class="v2-tile v2-t-correct">E</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">3</div>
            <h3 class="v2-htp-title">Solve the puzzle</h3>
            <p class="v2-htp-desc">Narrow down your guesses using the clues to solve the puzzle and keep your streak alive.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-reveal">
                <span class="v2-tile v2-t-correct">P</span>
                <span class="v2-tile v2-t-correct">R</span>
                <span class="v2-tile v2-t-correct">I</span>
                <span class="v2-tile v2-t-correct">D</span>
                <span class="v2-tile v2-t-correct">E</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- HTP: Guessing Engine (Country, Movie, Flag) -->
      <div id="htp-guessing" class="v2-htp-template" style="display: none;">
        <div class="v2-htp-grid">
          <div class="v2-htp-card">
            <div class="v2-htp-badge">1</div>
            <h3 class="v2-htp-title">Read the clues</h3>
            <p class="v2-htp-desc">A new hint is revealed with each wrong guess. Use your knowledge to narrow down the answer.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-list">
                <div class="v2-demo-hint">Starts with "A"</div>
                <div class="v2-demo-hint locked">🔒 Locked</div>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">2</div>
            <h3 class="v2-htp-title">Make a guess</h3>
            <p class="v2-htp-desc">Type your answer. If you're playing a geography game, you'll see distance and direction hints.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-guess-bar">
                <span>FRANCE</span>
                <span style="color: var(--v2-orange);">1200km ↗️</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">3</div>
            <h3 class="v2-htp-title">Find the answer</h3>
            <p class="v2-htp-desc">Solve it in as few guesses as possible. The fewer hints you need, the better!</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-guess-bar success">
                <span>GERMANY</span>
                <span>🎉</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- HTP: Word Puzzle Engine (Hangman, Scramble) -->
      <div id="htp-word-puzzle" class="v2-htp-template" style="display: none;">
        <div class="v2-htp-grid">
          <div class="v2-htp-card">
            <div class="v2-htp-badge">1</div>
            <h3 class="v2-htp-title">Look at the blanks</h3>
            <p class="v2-htp-desc">You are given empty spaces representing the letters of a hidden word.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row">
                <span class="v2-line">_</span>
                <span class="v2-line">_</span>
                <span class="v2-line">_</span>
                <span class="v2-line">_</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">2</div>
            <h3 class="v2-htp-title">Guess letters</h3>
            <p class="v2-htp-desc">Pick letters you think are in the word. Careful, too many wrong guesses will cost you the game.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row">
                <span class="v2-line v2-filled">W</span>
                <span class="v2-line">_</span>
                <span class="v2-line v2-filled">R</span>
                <span class="v2-line">_</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">3</div>
            <h3 class="v2-htp-title">Complete the word</h3>
            <p class="v2-htp-desc">Fill in all the blanks to solve the puzzle and win!</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-win-simple">
                <span class="v2-tile v2-t-correct">W</span>
                <span class="v2-tile v2-t-correct">O</span>
                <span class="v2-tile v2-t-correct">R</span>
                <span class="v2-tile v2-t-correct">D</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- HTP: Word Scramble -->
      <div id="htp-word-scramble" class="v2-htp-template" style="display: none;">
        <div class="v2-htp-grid">
          <div class="v2-htp-card">
            <div class="v2-htp-badge">1</div>
            <h3 class="v2-htp-title">Look at the scramble</h3>
            <p class="v2-htp-desc">You are given a set of scrambled letters that form a hidden word.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-scramble-shuffle">
                <span class="v2-tile">O</span>
                <span class="v2-tile">D</span>
                <span class="v2-tile">W</span>
                <span class="v2-tile">R</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">2</div>
            <h3 class="v2-htp-title">Rearrange letters</h3>
            <p class="v2-htp-desc">Click or type the letters in the correct order to build the word.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row">
                <span class="v2-line v2-filled">W</span>
                <span class="v2-line v2-filled">O</span>
                <span class="v2-line">_</span>
                <span class="v2-line">_</span>
              </div>
            </div>
          </div>
          <div class="v2-htp-card">
            <div class="v2-htp-badge">3</div>
            <h3 class="v2-htp-title">Complete the word</h3>
            <p class="v2-htp-desc">Solve the scramble to win the puzzle and keep your streak alive.</p>
            <div class="v2-htp-visual">
              <div class="v2-demo-row v2-anim-win-simple">
                <span class="v2-tile v2-t-correct">W</span>
                <span class="v2-tile v2-t-correct">O</span>
                <span class="v2-tile v2-t-correct">R</span>
                <span class="v2-tile v2-t-correct">D</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 5 — PLAYER PROGRESS
       ═══════════════════════════════════════════════════════ -->
  <section class="v2-progress-section">
    <div class="container">
      <div class="v2-progress-card" id="v2-progress">
        <div class="v2-progress-left">
          <div class="v2-xp-ring-wrap">
            <svg class="v2-xp-ring" viewBox="0 0 120 120">
              <circle class="v2-xp-track" cx="60" cy="60" r="52" />
              <circle class="v2-xp-fill" cx="60" cy="60" r="52" id="v2-xp-circle" />
              <text x="60" y="54" class="v2-xp-level" id="v2-xp-level-text">1</text>
              <text x="60" y="72" class="v2-xp-label">LEVEL</text>
            </svg>
          </div>
        </div>

        <div class="v2-progress-center">
          <h3 class="v2-progress-title">Your Journey</h3>
          <div class="v2-stat-row">
            <div class="v2-mini-stat">
              <span class="v2-mini-val" id="v2-stat-played">0</span>
              <span class="v2-mini-label">Played</span>
            </div>
            <div class="v2-mini-stat">
              <span class="v2-mini-val" id="v2-stat-wins">0</span>
              <span class="v2-mini-label">Wins</span>
            </div>
            <div class="v2-mini-stat">
              <span class="v2-mini-val v2-streak-val" id="v2-stat-streak">0</span>
              <span class="v2-mini-label">🔥 Streak</span>
            </div>
            <div class="v2-mini-stat">
              <span class="v2-mini-val" id="v2-stat-rate">0%</span>
              <span class="v2-mini-label">Win Rate</span>
            </div>
          </div>
        </div>

        <div class="v2-progress-right">
          <div class="v2-next-ach" id="v2-next-ach">
            <span class="v2-ach-icon">🏆</span>
            <div class="v2-ach-info">
              <span class="v2-ach-tag">Next Achievement</span>
              <span class="v2-ach-name" id="v2-ach-name">First Win</span>
              <span class="v2-ach-desc" id="v2-ach-desc">Win your first game to unlock</span>
            </div>
          </div>
          <a href="/stats/" class="v2-link-subtle">View Full Stats →</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       SECTION 6 — SEO CONTENT
       ═══════════════════════════════════════════════════════ -->
  <section class="seo-content container" style="margin-top: 4rem; margin-bottom: 4rem; font-size: 1rem; color: var(--muted); opacity: 0.9;">
    
    <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 2rem; gap: 1rem;">
      <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
      <h2 style="font-family: 'Bebas Neue', sans-serif; font-size: 2.5rem; letter-spacing: 2px; margin: 0; color: var(--text);">WHO ARE WE</h2>
      <div style="height: 2px; flex: 1; background: var(--border); opacity: 0.5;"></div>
    </div>

    <h1 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.5rem; letter-spacing: 1px; color: var(--text); margin-bottom: 1rem;">THE ULTIMATE HUB FOR FREE ONLINE WORD GAMES</h1>
    
    <h2 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.25rem; letter-spacing: 1px; color: var(--text); margin-top: 1.5rem; margin-bottom: 0.5rem;">WELCOME TO EVERYWORDGAMES: YOUR DAILY PUZZLE DESTINATION</h2>
    <p style="margin-bottom: 1rem;">If you are searching for the best <strong>free online word games</strong>, you have found your new daily destination. At EveryWordGames, we believe that challenging your mind should be fun, accessible, and completely free. Whether you have a five-minute break during your workday or you are settling in for a relaxing weekend puzzle session, our platform offers a massive variety of challenges designed for players of all skill levels. Jump right into our <strong>daily word puzzles online</strong> with absolutely no downloads required. Start building your daily win streak, earn XP, and unlock achievements today!</p>

    <h2 style="font-family: 'Bebas Neue', sans-serif; font-size: 1.25rem; letter-spacing: 1px; color: var(--text); margin-top: 1.5rem; margin-bottom: 0.5rem;">EXPLORE OUR COLLECTION OF PUZZLES AND TRIVIA</h2>
    <p style="margin-bottom: 1rem;">We are constantly expanding our library to bring you the most engaging browser games on the internet. Here is a taste of what you can play right now:</p>

    <h3 style="font-size: 1em; margin-top: 1rem;">The 5 Letter Word Guess Game</h3>
    <p style="margin-bottom: 1rem;">Test your vocabulary and logic skills with our flagship <strong>5 letter word guess game</strong>. The rules are simple: you have six attempts to figure out the hidden daily word. With crisp color feedback guiding every move you make, this fast-paced puzzle is the ultimate test of your deduction skills. Share your daily stats with friends and see who can keep their win streak alive the longest!</p>

    <h3 style="font-size: 1em; margin-top: 1rem;">Guess the Country Game</h3>
    <p style="margin-bottom: 1rem;">Put your global knowledge to the ultimate test! If you enjoy geography trivia, this will quickly become your favorite daily habit. We offer multiple exciting ways to play. You can challenge yourself to <strong>guess country by shape</strong>, relying purely on the map outlines and silhouettes of nations around the globe. If you consider yourself a vexillology expert, try to <strong>guess the country by flag</strong>. We even feature region-specific challenges, so if you want to focus your map skills, you can jump into the <strong>guess the country Europe</strong> edition.</p>

    <h3 style="font-size: 1em; margin-top: 1rem;">Free Hangman Game Online &amp; Word Scrambles</h3>
    <p style="margin-bottom: 1rem;">Sometimes, the classics are exactly what you need. Dive into our <strong>free hangman game online</strong> to guess the hidden phrase letter by letter before your misses run out. If you prefer a different kind of letter puzzle, test your speed with our <strong>word scramble games free</strong> of charge, where you must quickly rearrange chaotic, shuffled letters into perfect words.</p>

    <h3 style="font-size: 1em; margin-top: 1rem;">Fun Vocabulary Games for All Ages</h3>
    <p style="margin-bottom: 1rem;">Our platform isn't just for puzzle veterans; it is a fantastic educational tool as well. We feature simple, engaging puzzles that serve as excellent <strong>sight word games</strong> for younger players looking to improve their spelling. Meanwhile, we offer challenging modes specifically designed for those wanting to <strong>play word games for adults</strong> that truly test the limits of their vocabulary.</p>

    <h2 style="font-size: 1em; margin-top: 1rem; margin-bottom: 0.5rem;">Are Word Games Good For Your Brain?</h2>
    <p style="margin-bottom: 1.5rem;">A question we hear often from our community is: <strong>are word games good for your brain</strong>? The scientific answer is a resounding yes! Keeping your mind active with <strong>brain training word games</strong> is a fantastic way to maintain cognitive health. So, <strong>do word games help your brain</strong>? Absolutely. Regularly engaging with logic puzzles, anagrams, and memory trivia can help improve your recall, enhance your problem-solving skills, and increase your daily focus. Every time you figure out a tricky scramble, survive a round of Hangman, or successfully identify a country by its borders, you are giving your brain a healthy, rewarding workout.</p>

    <div id="faq-section" style="margin-top: 2rem;">
        <h2 style="font-size: 1em; margin-bottom: 1rem;">Frequently Asked Questions About Our Free Online Word Games</h2>

        <details class="faq-item" style="margin-bottom: 0.5rem; background: var(--surface); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border);">
            <summary style="font-weight: 700; cursor: pointer; outline: none; list-style-position: inside;">What are the best free word games online?</summary>
            <p style="margin-top: 0.5rem; padding-left: 1rem;">If you are looking for the best <strong>free word games online</strong>, EveryWordGames offers a massive library of daily challenges. You can play 5-letter guesses, classic hangman, and <strong>fun word games</strong> directly in your browser with absolutely no downloads required.</p>
        </details>

        <details class="faq-item" style="margin-bottom: 0.5rem; background: var(--surface); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border);">
            <summary style="font-weight: 700; cursor: pointer; outline: none; list-style-position: inside;">Are word games good for your brain?</summary>
            <p style="margin-top: 0.5rem; padding-left: 1rem;">Yes! Many players ask us, <strong>are word games good for your brain</strong>? Engaging with daily vocabulary puzzles is a fantastic form of cognitive exercise. Regularly challenging your mind helps improve problem-solving abilities, enhances processing speed, and strengthens short-term memory.</p>
        </details>

        <details class="faq-item" style="margin-bottom: 0.5rem; background: var(--surface); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border);">
            <summary style="font-weight: 700; cursor: pointer; outline: none; list-style-position: inside;">Do word games help your brain prevent cognitive decline?</summary>
            <p style="margin-top: 0.5rem; padding-left: 1rem;">Absolutely. If you are wondering, <strong>do word games help your brain</strong>, scientific studies suggest that keeping the mind active with puzzles builds cognitive reserve. Playing <strong>free word games for adults</strong> regularly helps keep neural pathways active and sharpens your focus.</p>
        </details>

        <details class="faq-item" style="margin-bottom: 0.5rem; background: var(--surface); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--border);">
            <summary style="font-weight: 700; cursor: pointer; outline: none; list-style-position: inside;">How to get better at word games?</summary>
            <p style="margin-top: 0.5rem; padding-left: 1rem;">Wondering <strong>how to get better at word games</strong>? The best strategy is consistent daily practice. Playing <strong>word games online free</strong> every day exposes you to new letter patterns, expands your vocabulary, and trains your brain to spot anagrams faster.</p>
