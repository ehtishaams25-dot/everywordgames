---
import GamePlayer from "@/components/GamePlayer.astro";
import GameGrid from "@/components/GameGrid.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { games } from "@/data/games";
import { getGameDetails } from "@/data/gameDetails";

export function getStaticPaths() {
  return games
    .filter((game) => !game.comingSoon)
    .map((game) => ({ params: { slug: game.slug }, props: { game } }));
}

const { game } = Astro.props;
const details = getGameDetails(game);
const similarGames = games
  .filter((g) => g.category === game.category && g.slug !== game.slug && !g.comingSoon)
  .slice(0, 4);
---

<SiteLayout title={`${game.name} - EveryWordGames`} description={game.description} path={`/games/${game.slug}/`}>
  <h1 class="sr-only">{game.name}</h1>
  <p class="sr-only game-seo-description">{game.description}</p>
  <GamePlayer game={game} />

  <section class="section">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding-top: 2rem;">
      <h2 style="margin-bottom: 1rem;">How to Play {game.name}</h2>
      <ul style="margin-bottom: 2rem; padding-left: 1.5rem; line-height: 1.6; color: var(--text);">
        {details.howToPlay.map((step) => <li>{step}</li>)}
      </ul>

      <h2 style="margin-bottom: 1rem;">Frequently Asked Questions</h2>
      <dl style="display: flex; flex-direction: column; gap: 1rem; color: var(--text);">
        {details.faqs.map((faq) => (
          <div>
            <dt style="font-weight: 700; margin-bottom: 0.25rem;">{faq.q}</dt>
            <dd style="margin: 0; color: var(--muted);">{faq.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  {similarGames.length > 0 && (
    <section class="section band" style="margin-top: 3rem;">
      <div class="container">
        <div class="section-header">
          <h2>Similar Games</h2>
          <p>You might also like these puzzles</p>
        </div>
        <GameGrid games={similarGames} />
      </div>
    </section>
  )}
</SiteLayout>
