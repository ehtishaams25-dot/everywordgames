---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="Privacy Policy - EveryWordGames"
  description="Read the EveryWordGames privacy policy for local stats, achievements, browser storage, and player data."
  path="/privacy"
>
  <section class="section">
    <div class="container seo-copy">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy Policy</h1>
      <p class="lede">EveryWordGames is designed as a local-first game site. Game stats, recent games, streaks, and achievements are stored in your browser storage on your device.</p>
      <p>We do not require accounts to play. If you clear browser storage, switch devices, or use a private browsing session, local progress may reset.</p>
      <p>Contact messages sent by email are handled only so we can respond to feedback, bug reports, and support requests.</p>
    </div>
  </section>
</SiteLayout>
