---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout title="Achievements - EveryWordGames" description="Track EveryWordGames achievements and local milestones." path="/achievements/">
  <section class="section">
    <div class="container">
      <p class="eyebrow">Milestones</p>
      <h1>Achievements</h1>
      <p class="lede">Achievements unlock from locally stored play history.</p>
      
      <div class="achievement-categories">
        <div class="category-group">
          <h2 class="category-header easy-header">
            <span class="dot easy-dot"></span> Easy Mode
          </h2>
          <div class="achievement-list" id="easy-list"></div>
        </div>

        <div class="category-group">
          <h2 class="category-header medium-header">
            <span class="dot medium-dot"></span> Medium Mode
          </h2>
          <div class="achievement-list" id="medium-list"></div>
        </div>

        <div class="category-group">
          <h2 class="category-header hard-header">
            <span class="dot hard-dot"></span> Hard Mode
          </h2>
          <div class="achievement-list" id="hard-list"></div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style is:global>
  .achievement-categories {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
    margin-top: 3rem;
  }

  .category-group {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .category-header {
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: 0.5px;
    margin: 0;
    text-transform: uppercase;
  }

  .easy-header {
    color: #22c55e;
  }

  .medium-header {
    color: #f59e0b;
  }

  .hard-header {
    color: #ef4444;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .easy-dot {
    background: #22c55e;
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.4);
  }

  .medium-dot {
    background: #f59e0b;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.4);
  }

  .hard-dot {
    background: #ef4444;
    box-shadow: 0 0 10px rgba(239, 68, 68, 0.4);
  }

  .achievement-list {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }
  
  .achievement {
    background: var(--surface);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 16px;
    padding: 1.25rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 1.2rem;
    opacity: 0.5;
    transition: all 0.3s ease;
    filter: grayscale(1);
  }

  .achievement-icon {
    font-size: 1.8rem;
    background: rgba(0, 0, 0, 0.05);
    width: 56px;
    height: 56px;
    min-width: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--muted);
  }
  
  .achievement-main {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex: 1;
  }

  .achievement-content {
    flex: 1;
  }
  
  .achievement-content strong {
    display: block;
    font-family: "Bebas Neue", sans-serif;
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 0.2rem;
    letter-spacing: 0.5px;
  }
  
  .achievement-content p {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.4;
  }
  
  .achievement-badge {
    background: rgba(0, 0, 0, 0.1);
    color: var(--muted);
    padding: 0.3rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* --- EASY CATEGORY UNLOCKED --- */
  .achievement.difficulty-easy.unlocked {
    opacity: 1;
    filter: grayscale(0);
    background: linear-gradient(145deg, rgba(34, 197, 94, 0.06) 0%, var(--surface) 100%);
    border: 1px solid rgba(34, 197, 94, 0.3);
    box-shadow: 0 8px 24px rgba(34, 197, 94, 0.04);
  }
  
  .achievement.difficulty-easy.unlocked .achievement-icon {
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
  }

  .achievement.difficulty-easy.unlocked .achievement-content strong {
    color: #22c55e;
  }

  .achievement.difficulty-easy.unlocked .achievement-badge {
    background: #22c55e;
    color: #ffffff;
  }

  /* --- MEDIUM CATEGORY UNLOCKED --- */
  .achievement.difficulty-medium.unlocked {
    opacity: 1;
    filter: grayscale(0);
    background: linear-gradient(145deg, rgba(245, 158, 11, 0.06) 0%, var(--surface) 100%);
    border: 1px solid rgba(245, 158, 11, 0.3);
    box-shadow: 0 8px 24px rgba(245, 158, 11, 0.04);
  }
  
  .achievement.difficulty-medium.unlocked .achievement-icon {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
  }

  .achievement.difficulty-medium.unlocked .achievement-content strong {
    color: #f59e0b;
  }

  .achievement.difficulty-medium.unlocked .achievement-badge {
    background: #f59e0b;
    color: #ffffff;
  }

  /* --- HARD CATEGORY UNLOCKED --- */
  .achievement.difficulty-hard.unlocked {
    opacity: 1;
    filter: grayscale(0);
    background: linear-gradient(145deg, rgba(239, 68, 68, 0.06) 0%, var(--surface) 100%);
    border: 1px solid rgba(239, 68, 68, 0.3);
    box-shadow: 0 8px 24px rgba(239, 68, 68, 0.04);
  }
  
  .achievement.difficulty-hard.unlocked .achievement-icon {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .achievement.difficulty-hard.unlocked .achievement-content strong {
    color: #ef4444;
  }

  .achievement.difficulty-hard.unlocked .achievement-badge {
    background: #ef4444;
    color: #ffffff;
  }
</style>

<script>
  import { achievements, loadStats } from "@/engines/playerStore";
  const stats = loadStats();

  const easyList = document.querySelector("#easy-list");
  const mediumList = document.querySelector("#medium-list");
  const hardList = document.querySelector("#hard-list");

  function renderList(listEl: Element | null, items: any[]) {
    if (!listEl) return;
    listEl.innerHTML = items
      .map((achievement) => {
        const unlocked = achievement.test(stats);
        return `
          <article class="achievement difficulty-${achievement.difficulty} ${unlocked ? "unlocked" : ""}">
            <div class="achievement-main">
              <div class="achievement-icon">
                ${unlocked ? "🏆" : "🔒"}
              </div>
              <div class="achievement-content">
                <strong>${achievement.name}</strong>
                <p class="muted">${achievement.description}</p>
              </div>
            </div>
            <span class="achievement-badge">${unlocked ? "Unlocked" : "Locked"}</span>
          </article>
        `;
      })
      .join("");
  }

  renderList(easyList, achievements.filter((a) => a.difficulty === "easy"));
  renderList(mediumList, achievements.filter((a) => a.difficulty === "medium"));
  renderList(hardList, achievements.filter((a) => a.difficulty === "hard"));
</script>
