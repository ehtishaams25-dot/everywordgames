---
import SiteLayout from "@/layouts/SiteLayout.astro";
---

<SiteLayout
  title="Terms of Use | EveryWordGames"
  description="Read the EveryWordGames terms of use for playing word games, guessing games, and puzzle games on the site."
  path="/terms/"
>
  <section class="section">
    <div class="container">
      <div class="seo-copy">
        <p class="eyebrow">Terms</p>
        <h1>Terms of Use</h1>
        <p class="lede">EveryWordGames provides browser-based word games, guessing games, and puzzle games for entertainment.</p>
        <p>You may play the games for personal use. Do not misuse the site, attempt to disrupt availability, or copy the platform as a competing service without permission.</p>
        <p>Game content, stats, achievements, and puzzle outcomes are provided as-is. We may update games, rules, datasets, and pages to improve the experience.</p>
      </div>
    </div>
  </section>
</SiteLayout>
