---
import "../styles.css";
import { footerNav, siteNav } from "@/data/games";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = "EveryWordGames - The Word Game Website for Every Game on the Market",
  description = "Play every word game available on the market at everywordgames.com. Find daily word games, Word Guess variants, multi-board puzzles, country guessing, and fast word puzzles in one place.",
  path = Astro.url.pathname
} = Astro.props;

const canonical = new URL(path, Astro.site ?? "https://everywordgames.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/Favicon.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/assets/hero-platform.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#0F172A" />
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary">
        <a class="brand" href="/">
          <span class="brand-mark">EW</span>
          <span>EveryWordGames</span>
        </a>
        <div class="nav-links">
          <div class="player-stats" style="display: flex; gap: 1rem; align-items: center; margin-right: 1rem;">
             <div class="streak" style="display: flex; align-items: center; justify-content: center; background: rgba(255,120,0,0.12); border: 1px solid rgba(255,120,0,0.3); color: #FF7800; border-radius: 20px; padding: 4px 10px; font-size: 12px; font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.5px;">
               🔥 12 day streak
             </div>
             <div class="xp" style="display: flex; align-items: center; justify-content: center; background: rgba(190,255,0,0.1); border: 1px solid rgba(190,255,0,0.25); color: #BEFF00; border-radius: 20px; padding: 4px 10px; font-size: 12px; font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.5px;">
               ⭐ 450 XP
             </div>
          </div>
          {siteNav.map((item) => (
            <a href={item.href} aria-current={path === item.href ? "page" : undefined}>{item.label}</a>
          ))}
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container footer-grid">
        <div>
          <strong style="font-size: 1.5rem; color: var(--text);">EveryWordGames</strong>
          <p style="margin-top: 0.5rem; max-width: 300px;">Play the best daily word games and puzzles. Free, fast, and fun.</p>
        </div>
        <div class="footer-links" aria-label="Footer">
          {footerNav.map((item) => <a class="pill" href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </footer>
    <script>
      import { loadStats, achievements } from "@/engines/playerStore";

      function showPopup(ach: { name: string; description: string }) {
        const popup = document.createElement("div");
        popup.className = "achievement-popup";
        popup.innerHTML = `
          <div class="achievement-icon">🏆</div>
          <div class="achievement-text">
            <strong>Achievement Unlocked!</strong>
            <span>${ach.name}</span>
          </div>
        `;
        document.body.appendChild(popup);

        // trigger reflow
        void popup.offsetWidth;

        setTimeout(() => popup.classList.add("show"), 100);
        setTimeout(() => {
          popup.classList.remove("show");
          setTimeout(() => popup.remove(), 500);
        }, 4000);
      }

      export function checkAndShowAchievements() {
        if (typeof localStorage === "undefined") return;
        const stats = loadStats();
        const shownIds = JSON.parse(
          localStorage.getItem("ewg:shownAchievements") || "[]",
        );
        let newlyShown = false;
        let delay = 0;

        for (const ach of achievements) {
          if (ach.test(stats) && !shownIds.includes(ach.id)) {
            shownIds.push(ach.id);
            newlyShown = true;
            setTimeout(() => showPopup(ach), delay);
            delay += 1500;
          }
        }

        if (newlyShown) {
          localStorage.setItem(
            "ewg:shownAchievements",
            JSON.stringify(shownIds),
          );
        }
      }

      // Run on page load
      checkAndShowAchievements();

      // Listen for game completion
      window.addEventListener("gamecompleted", () => {
        checkAndShowAchievements();
      });
    </script>
  </body>
</html>
