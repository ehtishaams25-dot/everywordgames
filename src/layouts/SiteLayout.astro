---
import "../styles.css";
import { footerNav, siteNav, games } from "@/data/games";

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = "EveryWordGames - The Word Game Website for Every Game on the Market",
  description = "Play every word game available on the market at everywordgames.com. Find daily word games, Word Guess variants, multi-board puzzles, country guessing, and fast word puzzles in one place.",
  path = Astro.url.pathname
} = Astro.props;

const canonical = new URL(path, Astro.site ?? "https://everywordgames.com").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/Favicon.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/assets/hero-platform.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="theme-color" content="#FDFBF7" />

    <style is:global>
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }
    </style>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DXT09C57E5" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-DXT09C57E5');
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="nav" aria-label="Primary">
        <a class="brand" href="/">
          <img src="/Favicon.png" alt="EveryWordGames Logo" style="width: 2.25rem; height: 2.25rem; border-radius: 8px;" />
          <span>EveryWordGames</span>
        </a>
        <button id="nav-toggle" class="hamburger" aria-label="Toggle Menu">
          <svg viewBox="0 0 24 24">
            <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
          </svg>
        </button>
        <div id="nav-links" class="nav-links">
          <div class="player-stats" style="display: flex; gap: 1rem; align-items: center; margin-right: 1rem;">
             <div id="nav-streak" class="streak" style="display: flex; align-items: center; justify-content: center; background: rgba(255,120,0,0.12); border: 1px solid rgba(255,120,0,0.3); color: #FF7800; border-radius: 20px; padding: 4px 10px; font-size: 12px; font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.5px;">
               🔥 0 win streak
             </div>
             <div id="nav-xp" class="xp" style="display: flex; align-items: center; justify-content: center; background: rgba(99,158,66,0.1); border: 1px solid rgba(99,158,66,0.3); color: #639E42; border-radius: 20px; padding: 4px 10px; font-size: 12px; font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.5px;">
               ⭐ 0 XP
             </div>
          </div>
          <a href="/stats/" aria-current={path === "/stats/" ? "page" : undefined}>Profile</a>
          <a href="/achievements/" aria-current={path === "/achievements/" ? "page" : undefined}>Awards</a>
          <a href="/blog/" aria-current={path === "/blog/" ? "page" : undefined}>Blog</a>
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <span class="icon-moon">🌙</span>
            <span class="icon-sun">☀️</span>
          </button>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mega-footer">
      <div class="mega-container">
        <div class="mega-top-row">
          <div class="mega-brand-info">
            <div class="brand" style="margin-bottom: 1rem;">
              <img src="/Favicon.png" alt="EveryWordGames Logo" style="width: 2.25rem; height: 2.25rem; border-radius: 8px;" />
              <span style="font-size: 1.5rem; font-weight: 800; color: var(--text);">EveryWordGames</span>
            </div>
            <p style="color: var(--muted); max-width: 320px; font-size: 1rem; line-height: 1.6;">Play the best daily word games and puzzles. Free, fast, and fun. No downloads or accounts required.</p>
          </div>
          
          <div class="mega-links-grid">
            <div class="mega-col">
              <h3 class="mega-heading">Top Games</h3>
              <ul class="mega-list">
                <li><a href="/games/5-letter-word-guess/">Word Guess</a></li>
                <li><a href="/games/guess-country/">Guess Country</a></li>
                <li><a href="/games/hangman/">Hangman</a></li>
                <li><a href="/">Play All Games</a></li>
              </ul>
            </div>
            <div class="mega-col">
              <h3 class="mega-heading">Explore</h3>
              <ul class="mega-list">
                {siteNav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
              </ul>
            </div>
            <div class="mega-col">
              <h3 class="mega-heading">Company</h3>
              <ul class="mega-list">
                {footerNav.map(item => <li><a href={item.href}>{item.label}</a></li>)}
                <li><a href="https://www.instagram.com/everywordgames/" target="_blank" rel="noopener noreferrer">Instagram</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="mega-branding">
          EVERYWORDGAMES
        </div>
      </div>

      <div class="sr-only">
        <h2>All Games Sitemap</h2>
        <ul>
          {siteNav.map(item => <li><a href={item.href}>{item.label}</a></li>)}
          {footerNav.map(item => <li><a href={item.href}>{item.label}</a></li>)}
          {games.filter(g => !g.comingSoon).map(game => (
            <li><a href={`/games/${game.slug}/`}>{game.name}</a></li>
          ))}
        </ul>
      </div>
    </footer>

    <style is:global>
      .mega-footer {
        background: var(--surface);
        border-top: 1px solid var(--border);
        padding: 4rem 0 0 0;
        margin-top: 4rem;
        overflow: hidden;
        position: relative;
      }
      
      /* Subtle gradient background pattern to give it a premium feel */
      .mega-footer::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at 50% 120%, rgba(99, 158, 66, 0.05), transparent 60%),
                    radial-gradient(circle at 100% 0%, rgba(255, 122, 0, 0.03), transparent 40%);
        pointer-events: none;
      }

      .mega-container {
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
      }

      .mega-top-row {
        display: flex;
        flex-wrap: wrap;
        gap: 4rem;
        justify-content: space-between;
        margin-bottom: 3rem;
      }

      .mega-brand-info {
        flex: 1 1 300px;
      }

      .mega-links-grid {
        flex: 2 1 500px;
        display: flex;
        flex-wrap: wrap;
        gap: 3rem;
        justify-content: space-between;
      }

      .mega-col {
        min-width: 140px;
      }

      .mega-heading {
        font-family: "Bebas Neue", sans-serif;
        font-size: 1.25rem;
        letter-spacing: 1px;
        color: var(--text);
        margin-bottom: 1.25rem;
        text-transform: uppercase;
      }

      .mega-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .mega-list a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.2s;
      }

      .mega-list a:hover {
        color: var(--v2-green, var(--green));
      }

      .mega-branding {
        font-family: "Bebas Neue", sans-serif;
        font-size: clamp(3rem, 12vw, 15rem);
        line-height: 0.8;
        font-weight: 900;
        text-align: center;
        letter-spacing: -2px;
        color: var(--text);
        opacity: 0.05;
        white-space: nowrap;
        user-select: none;
        margin-top: 2rem;
        padding-bottom: 0;
        transform: translateY(15%);
      }
      
      [data-theme="dark"] .mega-branding {
        opacity: 0.08;
      }

      @media (max-width: 768px) {
        .mega-top-row { gap: 2.5rem; flex-direction: column; }
        .mega-links-grid { gap: 2rem; justify-content: flex-start; }
        .mega-branding { letter-spacing: -1px; transform: translateY(10%); }
      }
    </style>
    <script>
      import { loadStats, achievements } from "@/engines/playerStore";

      function showPopup(ach: { name: string; description: string }) {
        const popup = document.createElement("div");
        popup.className = "achievement-popup";
        popup.innerHTML = `
          <div class="achievement-icon">🏆</div>
          <div class="achievement-text">
            <strong>Achievement Unlocked!</strong>
            <span>${ach.name}</span>
          </div>
        `;
        document.body.appendChild(popup);

        // trigger reflow
        void popup.offsetWidth;

        setTimeout(() => popup.classList.add("show"), 100);
        setTimeout(() => {
          popup.classList.remove("show");
          setTimeout(() => popup.remove(), 500);
        }, 4000);
      }

      export function checkAndShowAchievements() {
        if (typeof localStorage === "undefined") return;
        const stats = loadStats();
        const shownIds = JSON.parse(
          localStorage.getItem("ewg:shownAchievements") || "[]",
        );
        let newlyShown = false;
        let delay = 0;

        for (const ach of achievements) {
          if (ach.test(stats) && !shownIds.includes(ach.id)) {
            shownIds.push(ach.id);
            newlyShown = true;
            setTimeout(() => showPopup(ach), delay);
            delay += 1500;
          }
        }

        if (newlyShown) {
          localStorage.setItem(
            "ewg:shownAchievements",
            JSON.stringify(shownIds),
          );
        }
      }

      export function updateNavStats() {
        if (typeof localStorage === "undefined") return;
        const stats = loadStats();
        const streakEl = document.getElementById("nav-streak");
        const xpEl = document.getElementById("nav-xp");
        
        if (streakEl) {
          streakEl.innerText = `🔥 ${stats.currentStreak} win streak`;
        }
        if (xpEl) {
          const xp = (stats.wins * 50) + (stats.played * 10);
          xpEl.innerText = `⭐ ${xp} XP`;
        }
      }

      // Run on page load
      checkAndShowAchievements();
      updateNavStats();

      // Listen for game completion
      window.addEventListener("gamecompleted", () => {
        checkAndShowAchievements();
        updateNavStats();
      });

      // Theme Toggle Logic
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
          const newTheme = isDark ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', newTheme);
          localStorage.setItem('theme', newTheme);
        });
      }

      // Mobile Nav Toggle Logic
      const navToggle = document.getElementById('nav-toggle');
      const navLinks = document.getElementById('nav-links');
      if (navToggle && navLinks) {
        navToggle.addEventListener('click', () => {
          navLinks.classList.toggle('active');
        });
      }
    </script>
  </body>
</html>
