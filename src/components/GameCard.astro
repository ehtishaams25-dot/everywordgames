---
import type { GameConfig } from "@/data/games";

interface Props {
  game: GameConfig;
}

const { game } = Astro.props;

let bannerUrl = "";
if (game.slug === "hangman") {
  bannerUrl = "/thumbnails/Hangman Thumbnail 1.png";
} else if (game.slug === "guess-country") {
  bannerUrl = "/thumbnails/Guess Country Thumbnail 2.png";
} else if (game.slug === "guess-movie") {
  bannerUrl = "/thumbnails/Guess Movie Thumbnail 1.png";
} else if (game.slug === "guess-anime") {
  bannerUrl = "/thumbnails/Guess Anime Thumbnail 1.png";
} else if (game.category === "wordle" || game.category === "multi-wordle") {
  bannerUrl = "/thumbnails/Word Guess Thumbnail .png";
} else if (game.slug === "daily-wordle") {
  bannerUrl = "/thumbnails/Word Guess Thumbnail .png";
} else if (game.category === "geography") {
  bannerUrl = "/thumbnails/Geography category 1.png";
} else if (game.category === "entertainment") {
  bannerUrl = "/thumbnails/Entertainment category 1.png";
} else if (game.category === "brands") {
  bannerUrl = "/thumbnails/brand category 1.png";
} else if (game.category === "word-games" || game.category === "daily") {
  bannerUrl = "/thumbnails/word category 1.png";
}

const initials = game.name
  .split(/\s+/)
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const linkHref = game.comingSoon ? "#" : `/games/${game.slug}`;
---

<a class="game-card" href={linkHref} aria-disabled={game.comingSoon ? "true" : undefined}>
  <div class="card-banner" style={!bannerUrl ? "background: linear-gradient(135deg, #1A1C18 0%, #2A2E24 100%); display: grid; place-items: center;" : ""}>
    {bannerUrl ? (
      <img src={bannerUrl} alt={game.name} />
    ) : (
      <span class="tile-icon" style="box-shadow: none;">{initials}</span>
    )}
    {game.daily && <span class="card-tag">DAILY</span>}
    {game.comingSoon && <span class="card-tag" style="color: #FF7800; border-color: rgba(255,120,0,0.3); background: rgba(255,120,0,0.15);">SOON</span>}
  </div>

  <div class="card-body">
    <span class="game-name">{game.name}</span>
    <span class="game-desc">{game.description}</span>
    <div class="play-btn">{game.comingSoon ? "Coming Soon" : "▶ Play"}</div>
  </div>
</a>
