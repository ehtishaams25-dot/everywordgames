---
import type { GameConfig } from "@/data/games";

interface Props {
  game: GameConfig;
}

const { game } = Astro.props;

let bannerUrl = "";
if (game.slug === "hangman") {
  bannerUrl = "/thumbnails/hangman_clay.png";
} else if (game.slug === "guess-country") {
  bannerUrl = "/thumbnails/guess_country_minimal_clay.png";
} else if (game.slug === "guess-flag") {
  bannerUrl = "/thumbnails/guess_flag_clay.png";
} else if (game.slug === "guess-capital") {
  bannerUrl = "/thumbnails/guess capital.png";
} else if (game.slug === "guess-movie") {
  bannerUrl = "/thumbnails/guess movie new.png";
} else if (game.slug === "guess-tv-show") {
  bannerUrl = "/thumbnails/guess tv show.png";
} else if (game.slug === "guess-anime") {
  bannerUrl = "/thumbnails/anime new.png";
} else if (game.slug === "antonym-challenge") {
  bannerUrl = "/thumbnails/antonym_clay.png";
} else if (game.slug === "missing-letters") {
  bannerUrl = "/thumbnails/missing_letters_clay.png";
} else if (game.slug === "synonym-challenge") {
  bannerUrl = "/thumbnails/synonym_clay.png";
} else if (game.slug === "word-scramble") {
  bannerUrl = "/thumbnails/word_scramble_clay.png";
} else if (game.slug === "merge-letters") {
  bannerUrl = "/thumbnails/merge_letters_clay.png";
} else if (game.slug === "word-search") {
  bannerUrl = "/thumbnails/word_search_clay.png";
} else if (game.slug === "type-destroy") {
  bannerUrl = "/thumbnails/type_destroy_clay.png";
} else if (game.category === "word-guess") {
  bannerUrl = "/thumbnails/word_guess_clay.png";
} else if (game.category === "multi-word-guess") {
  bannerUrl = "";
} else if (game.slug === "daily-word-guess") {
  bannerUrl = "/thumbnails/word_guess_clay.png";
} else if (game.category === "geography") {
  bannerUrl = "/thumbnails/geography category.png";
} else if (game.category === "entertainment") {
  bannerUrl = "/thumbnails/movie category.png";
} else if (game.category === "brands") {
  bannerUrl = ""; // No brand thumbnail provided in update, falling back to initials.
} else if (game.category === "word-games" || game.category === "daily") {
  bannerUrl = "/thumbnails/word category.png";
}

const initials = game.name
  .split(/\s+/)
  .map((part) => part[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const fallbackText = game.category === "multi-word-guess" && game.boardCount ? game.boardCount.toString() : initials;

const linkHref = game.comingSoon ? undefined : `/games/${game.slug}/`;
const CardWrapper = game.comingSoon ? 'div' : 'a';
---

<CardWrapper class="v2-feature-card game-card" href={linkHref} style={game.comingSoon ? "cursor: default;" : undefined}>
  <div class="v2-feature-img">
    {bannerUrl ? (
      <img src={bannerUrl} alt={game.name} loading="lazy" />
    ) : (
      <div class="fallback-img">
        <span class="clay-tile">{fallbackText}</span>
      </div>
    )}
    <div class="v2-feature-overlay"></div>
    {game.daily && <span class="v2-feature-diff" style="top:auto; bottom:12px; left:12px; right:auto; background:var(--v2-orange); color:#fff;">DAILY</span>}
    {game.comingSoon && (
      <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; backdrop-filter: blur(2px);">
        <span style="background: rgba(255,122,0,0.9); color: white; padding: 0.5rem 1rem; font-weight: 800; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; border-radius: 4px;">Coming Soon</span>
      </div>
    )}
    {!game.comingSoon && <span class="v2-feature-diff" data-diff={game.difficulty || "Easy"}>{game.difficulty || "Easy"}</span>}
  </div>

  <div class="v2-feature-body">
    <h3 class="v2-feature-name">{game.name}</h3>
    <p class="v2-feature-hook">{game.description}</p>
  </div>
</CardWrapper>

<style>
  .fallback-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--surface2);
  }
  .clay-tile {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
    height: 80px;
    padding: 0 16px;
    background: var(--v2-green);
    border-radius: 16px;
    font-family: "Bebas Neue", sans-serif;
    font-size: 4.5rem;
    color: #fff;
    box-shadow: 
      inset -4px -4px 8px rgba(0,0,0,0.25),
      inset 4px 4px 8px rgba(255,255,255,0.4),
      4px 8px 16px rgba(0,0,0,0.15);
    text-shadow: 1px 2px 4px rgba(0,0,0,0.2);
  }
</style>
