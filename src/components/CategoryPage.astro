---
import GameGrid from "./GameGrid.astro";
import SiteLayout from "@/layouts/SiteLayout.astro";
import { categoryLabels, games, type GameCategory } from "@/data/games";

interface Props {
  title: string;
  description: string;
  categories: GameCategory[];
  path: string;
}

const { title, description, categories, path } = Astro.props;
const pageGames = games.filter((game) => categories.includes(game.category));
---

<SiteLayout title={`${title} - EveryWordGames`} description={description} path={path}>
  <section class="section">
    <div class="container">
      <h1 style="font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 0.5rem;">{title}</h1>
      <p class="lede" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%;">{description}</p>
    </div>
  </section>
  <section class="section band">
    <div class="container">
      <GameGrid games={pageGames} />
    </div>
  </section>
</SiteLayout>
