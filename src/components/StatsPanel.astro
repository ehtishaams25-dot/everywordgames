<script>
  import { loadStats, achievements } from "@/engines/playerStore";
  import { games } from "@/data/games";

  // Emojis mapping
  const achievementEmojis: Record<string, string> = {
    "vibe-check": "🎮",
    "first-win": "🏆",
    "three-wins": "🍳",
    "three-streak": "🔒",
    "daily-regular": "📅",
    "classic-five": "🔠",
    "puzzle-runner": "🧩",
    "skill-issue": "🤡",
    "ten-wins": "👑",
    "twenty-five-wins": "🚜",
    "seven-streak": "⚡",
    "word-master": "🗣️",
    "quick-solve": "🎯",
    "multi-board": "🧠",
    "geography-expert": "🌍",
    "hustle-culture": "💼",
    "world-tour": "🗺️",
    "fifty-wins": "🧱",
    "hundred-wins": "🌿",
    "thirty-streak": "💫",
    "fast-furious": "🏎️",
    "mega-mind": "🤖",
    "no-life": "🪦"
  };

  const avatarList = [
    { emoji: "👽", minLvl: 1 },
    { emoji: "🎮", minLvl: 1 },
    { emoji: "👾", minLvl: 1 },
    { emoji: "🤖", minLvl: 2 },
    { emoji: "⚡", minLvl: 2 },
    { emoji: "🧙‍♂️", minLvl: 3 },
    { emoji: "🧠", minLvl: 3 },
    { emoji: "👑", minLvl: 4 },
    { emoji: "🌍", minLvl: 4 },
    { emoji: "🐉", minLvl: 5 },
    { emoji: "🦁", minLvl: 5 },
    { emoji: "🦊", minLvl: 6 },
    { emoji: "💫", minLvl: 6 },
    { emoji: "🔮", minLvl: 7 }
  ];

  const levelTitles: Record<number, string> = {
    1: "Novice Word Slinger",
    2: "Lexicon Explorer",
    3: "Puzzler Apprentice",
    4: "Spelling Bee Champion",
    5: "Vocab Gladiator",
    6: "Anagram Archmage",
    7: "Aura Word Master",
    8: "Dictionary Deity"
  };

  function getLevelTitle(lvl: number) {
    if (lvl >= 8) return levelTitles[8];
    return levelTitles[lvl] || `Level ${lvl} Explorer`;
  }

  function getNextReward(lvl: number) {
    const nextAvatars = avatarList.filter(a => a.minLvl === lvl + 1);
    if (nextAvatars.length > 0) {
      return {
        name: `${nextAvatars.map(a => a.emoji).join(" ")} New Avatars`,
        requirement: `Unlocks at Level ${lvl + 1}`
      };
    }
    if (lvl === 1) return { name: "🤖 Level 2 Robot Avatars", requirement: "Unlocks at Level 2" };
    if (lvl === 2) return { name: "🧙‍♂️ Level 3 Wizard Avatars", requirement: "Unlocks at Level 3" };
    if (lvl === 3) return { name: "👑 Level 4 Royal Avatars", requirement: "Unlocks at Level 4" };
    if (lvl === 4) return { name: "🐉 Level 5 Mystic Avatars", requirement: "Unlocks at Level 5" };
    if (lvl === 5) return { name: "🦊 Level 6 Beast Avatars", requirement: "Unlocks at Level 6" };
    return { name: "🔮 Level 7 Oracle Avatars", requirement: "Unlocks at Level 7" };
  }

  // Load stats and populate
  const stats = loadStats();
  const xp = (stats.wins * 50) + (stats.played * 10);
  const level = Math.floor(xp / 500) + 1;
  const currentLevelXp = xp % 500;

  // 1. Setup username & avatar
  const usernameDisplay = document.getElementById("display-username");
  const usernameInput = document.getElementById("username-input") as HTMLInputElement;
  const displayAvatar = document.getElementById("display-avatar");
  
  if (usernameDisplay && usernameInput) {
    const savedName = localStorage.getItem("ewg:username") || "Player 1";
    usernameDisplay.textContent = savedName;
    usernameInput.value = savedName;
  }

  if (displayAvatar) {
    const savedAvatar = localStorage.getItem("ewg:avatar") || "👽";
    displayAvatar.textContent = savedAvatar;
  }

  // 2. Inline name editing
  const editBtn = document.getElementById("edit-name-btn");
  const saveBtn = document.getElementById("save-name-btn");
  const cancelBtn = document.getElementById("cancel-name-btn");
  const displayGroup = document.getElementById("name-display-group");
  const editGroup = document.getElementById("name-edit-group");

  editBtn?.addEventListener("click", () => {
    displayGroup?.classList.add("hidden");
    editGroup?.classList.remove("hidden");
    usernameInput?.focus();
  });

  function saveName() {
    if (usernameInput && usernameDisplay) {
      const newName = usernameInput.value.trim() || "Player 1";
      localStorage.setItem("ewg:username", newName);
      usernameDisplay.textContent = newName;
      window.dispatchEvent(new Event("namechanged"));
    }
    displayGroup?.classList.remove("hidden");
    editGroup?.classList.add("hidden");
  }

  saveBtn?.addEventListener("click", saveName);
  usernameInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") saveName();
  });

  cancelBtn?.addEventListener("click", () => {
    if (usernameInput && usernameDisplay) {
      usernameInput.value = usernameDisplay.textContent || "Player 1";
    }
    displayGroup?.classList.remove("hidden");
    editGroup?.classList.add("hidden");
  });

  // 3. Avatar popover dialog
  const avatarTrigger = document.getElementById("avatar-trigger-btn");
  const avatarPopover = document.getElementById("avatar-popover");
  const closePopover = document.getElementById("close-avatar-popover");
  const avatarGrid = document.getElementById("avatar-options");

  avatarTrigger?.addEventListener("click", () => {
    renderAvatarOptions();
    avatarPopover?.classList.toggle("hidden");
  });

  closePopover?.addEventListener("click", () => {
    avatarPopover?.classList.add("hidden");
  });

  document.addEventListener("click", (e) => {
    if (avatarPopover && avatarTrigger && !avatarPopover.contains(e.target as Node) && !avatarTrigger.contains(e.target as Node)) {
      avatarPopover.classList.add("hidden");
    }
  });

  function renderAvatarOptions() {
    if (!avatarGrid) return;
    const currentAvatar = localStorage.getItem("ewg:avatar") || "👽";
    
    avatarGrid.innerHTML = avatarList.map(item => {
      const isLocked = level < item.minLvl;
      const isSelected = currentAvatar === item.emoji;
      
      return `
        <button 
          type="button" 
          class="avatar-opt ${isLocked ? "locked" : ""} ${isSelected ? "selected" : ""}" 
          data-emoji="${item.emoji}"
          ${isLocked ? "disabled" : ""}
          title="${isLocked ? `Unlocks at Level ${item.minLvl}` : `Select ${item.emoji}`}"
        >
          ${item.emoji}
        </button>
      `;
    }).join("");

    const opts = avatarGrid.querySelectorAll(".avatar-opt:not(.locked)");
    opts.forEach(btn => {
      btn.addEventListener("click", (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const emoji = target.getAttribute("data-emoji") || "👽";
        localStorage.setItem("ewg:avatar", emoji);
        if (displayAvatar) displayAvatar.textContent = emoji;
        avatarPopover?.classList.add("hidden");
        window.dispatchEvent(new Event("avatarchanged"));
      });
    });
  }

  // 4. Set Profile Titles & XP
  const levelBadge = document.getElementById("profile-level-badge");
  if (levelBadge) levelBadge.textContent = `LVL ${level}`;

  const rankTitle = document.getElementById("player-rank-title");
  if (rankTitle) rankTitle.textContent = getLevelTitle(level);

  const xpProgressText = document.getElementById("xp-progress-text");
  if (xpProgressText) xpProgressText.textContent = `${currentLevelXp} / 500 XP`;

  const xpLevelTarget = document.getElementById("xp-level-target");
  if (xpLevelTarget) xpLevelTarget.textContent = `XP to Level ${level + 1}`;

  const xpBar = document.getElementById("xp-progress-bar");
  if (xpBar) {
    const progressPercent = (currentLevelXp / 500) * 100;
    xpBar.style.width = `${progressPercent}%`;
  }

  const currentStreakEl = document.getElementById("card-current-streak");
  if (currentStreakEl) currentStreakEl.textContent = String(stats.currentStreak);

  const bestStreakEl = document.getElementById("card-best-streak");
  if (bestStreakEl) bestStreakEl.textContent = String(stats.longestStreak);

  const nextReward = getNextReward(level);
  const rewardNameEl = document.getElementById("next-reward-name");
  const rewardReqEl = document.getElementById("next-reward-requirement");
  if (rewardNameEl) rewardNameEl.textContent = nextReward.name;
  if (rewardReqEl) rewardReqEl.textContent = nextReward.requirement;


  // 5. Populate Highlight Statistics Cards
  const winRate = stats.played ? Math.round((stats.wins / stats.played) * 100) : 0;
  const averageSolve = stats.wins ? Math.round(stats.totalSolveSeconds / stats.wins) : null;

  const winRatePercent = document.getElementById("winrate-percent");
  if (winRatePercent) winRatePercent.textContent = `${winRate}%`;

  const winRateCircle = document.getElementById("winrate-circle");
  if (winRateCircle) {
    winRateCircle.setAttribute("stroke-dasharray", `${winRate}, 100`);
  }

  const winrateDetails = document.getElementById("winrate-details");
  if (winrateDetails) {
    const winPlural = stats.wins === 1 ? "Win" : "Wins";
    const lossPlural = stats.losses === 1 ? "Loss" : "Losses";
    winrateDetails.textContent = `${stats.wins} ${winPlural} • ${stats.losses} ${lossPlural}`;
  }

  // Supporting Stat Cards
  const valPlayed = document.getElementById("val-played");
  if (valPlayed) valPlayed.textContent = String(stats.played);

  const valCurrentStreak = document.getElementById("val-current-streak");
  if (valCurrentStreak) valCurrentStreak.textContent = String(stats.currentStreak);

  const valBestStreak = document.getElementById("val-best-streak");
  if (valBestStreak) valBestStreak.textContent = `Best: ${stats.longestStreak}`;

  const valFastest = document.getElementById("val-fastest");
  if (valFastest) valFastest.textContent = stats.fastestSolve !== null ? `${stats.fastestSolve}s` : "--";

  const valAverage = document.getElementById("val-average");
  if (valAverage) valAverage.textContent = averageSolve !== null ? `Average: ${averageSolve}s` : "Average: --";

  const valFavGame = document.getElementById("val-favgame");
  const valFavGamePlays = document.getElementById("val-favgame-plays");
  if (valFavGame) {
    if (stats.favoriteGame && stats.favoriteGame !== "None yet") {
      const fGame = games.find(g => g.slug === stats.favoriteGame);
      valFavGame.textContent = fGame ? fGame.name : stats.favoriteGame;
      
      const playsCount = stats.gameCounts[stats.favoriteGame] ?? 0;
      if (valFavGamePlays) {
        valFavGamePlays.textContent = playsCount === 1 ? "1 Play" : `${playsCount} Plays`;
      }
    } else {
      valFavGame.textContent = "None yet";
      if (valFavGamePlays) valFavGamePlays.textContent = "0 Plays";
    }
  }


  // 6. Win / Loss Donut Chart Card
  const donutSegmentWins = document.getElementById("donut-segment-wins");
  const donutWinsVal = document.getElementById("donut-wins-val");
  const donutRatioDetails = document.getElementById("donut-ratio-details");
  
  if (donutSegmentWins && donutWinsVal) {
    donutWinsVal.textContent = String(stats.wins);
    if (stats.played > 0) {
      const winRatioVal = (stats.wins / stats.played) * 100;
      donutSegmentWins.setAttribute("stroke-dasharray", `${winRatioVal} 100`);
    } else {
      donutSegmentWins.setAttribute("stroke-dasharray", `0 100`);
    }
  }

  if (donutRatioDetails) {
    const winPlural = stats.wins === 1 ? "Win" : "Wins";
    const lossPlural = stats.losses === 1 ? "Loss" : "Losses";
    donutRatioDetails.textContent = `${stats.wins} ${winPlural} • ${stats.losses} ${lossPlural}`;
  }


  // 7. Most Played Modes Progress Bar Card
  const categoryBars = document.getElementById("category-bars");
  if (categoryBars) {
    // Sort game counts descending
    const playedModes = Object.entries(stats.gameCounts)
      .map(([slug, count]) => {
        const game = games.find(g => g.slug === slug);
        return {
          name: game ? game.name : slug,
          plays: count
        };
      })
      .sort((a, b) => b.plays - a.plays)
      .slice(0, 4); // top 4 modes

    let maxPlays = 0;
    playedModes.forEach(mode => {
      if (mode.plays > maxPlays) maxPlays = mode.plays;
    });

    if (playedModes.length === 0) {
      categoryBars.innerHTML = `
        <div style="text-align: center; color: var(--muted); padding: 1.5rem 0; font-size: 12px; font-weight: bold; text-transform: uppercase;">
          No play data available yet
        </div>
      `;
    } else {
      categoryBars.innerHTML = playedModes.map(mode => {
        const widthPercent = maxPlays > 0 ? (mode.plays / maxPlays) * 100 : 0;
        return `
          <div class="cat-bar-item">
            <div class="cat-bar-header">
              <span class="cat-bar-label">${mode.name}</span>
              <span class="cat-bar-value">${mode.plays} ${mode.plays === 1 ? 'play' : 'plays'}</span>
            </div>
            <div class="cat-bar-track">
              <div class="cat-bar-fill" style="width: ${widthPercent}%;"></div>
            </div>
          </div>
        `;
      }).join("");
    }
  }


  // 8. Recent Activity Timeline Cards
  const timelineFlow = document.getElementById("timeline-flow");
  if (timelineFlow) {
    const rawActivities = localStorage.getItem("ewg:activities");
    let activities = [];
    
    if (rawActivities) {
      activities = JSON.parse(rawActivities);
    }

    // Seed fallback if empty
    if (activities.length === 0 && stats.played > 0) {
      const seedTime = Date.now() - 3600000;
      
      if (stats.wins > 0) {
        const favName = games.find(g => g.slug === stats.favoriteGame)?.name || "Word Game";
        activities.push({
          id: "seed-win",
          type: "win",
          text: `Won ${favName} Challenge`,
          timestamp: seedTime
        });
      }
      
      if (stats.fastestSolve !== null) {
        activities.push({
          id: "seed-record",
          text: `🏆 New Personal Best: ${stats.fastestSolve}s solve time!`,
          timestamp: seedTime - 600000
        });
      }

      if (stats.longestStreak > 0) {
        activities.push({
          id: "seed-streak",
          text: `🔥 Reached milestone streak of ${stats.longestStreak} games!`,
          timestamp: seedTime - 1200000
        });
      }

      if (level > 1) {
        activities.push({
          id: "seed-lvl",
          text: `⭐ Leveled Up to Level ${level}!`,
          timestamp: seedTime - 1800000
        });
      }

      if (activities.length === 0) {
        activities.push({
          id: "seed-play",
          type: "play",
          text: "Started your word puzzle adventure!",
          timestamp: Date.now() - 60000
        });
      }
    }

    if (activities.length === 0) {
      timelineFlow.innerHTML = `
        <div style="grid-column: 1 / -1; text-align: center; color: var(--muted); padding: var(--space-3); font-size: 13px; font-weight: bold; text-transform: uppercase;">
          No activities logged yet
        </div>
      `;
    } else {
      timelineFlow.innerHTML = activities.slice(0, 4).map((item: any) => {
        // Format time
        const dateObj = new Date(item.timestamp);
        const timeStr = dateObj.toLocaleTimeString(undefined, {
          hour: '2-digit',
          minute: '2-digit'
        });

        // Determine structured details
        let categoryText = "Activity";
        let emoji = "🎮";
        let detailText = item.text;

        if (item.type === "record" || item.text.includes("New Personal Best")) {
          categoryText = "Personal Best";
          emoji = "🏆";
          detailText = item.text.replace("🏆 ", "").replace("New Personal Best: ", "");
        } else if (item.type === "streak" || item.text.includes("streak")) {
          categoryText = "Streak Milestone";
          emoji = "🔥";
          detailText = item.text.replace("🔥 ", "");
        } else if (item.type === "levelup" || item.text.includes("Level")) {
          categoryText = "Level Up";
          emoji = "⭐";
          detailText = item.text.replace("⭐ ", "");
        } else if (item.type === "win") {
          categoryText = "Game Won";
          emoji = "🎯";
          detailText = item.text;
        } else if (item.type === "play") {
          categoryText = "Game Played";
          emoji = "🎮";
          detailText = item.text;
        }

        return `
          <div class="timeline-card">
            <div class="timeline-card-header">
              <span>${emoji}</span>
              <span>${categoryText}</span>
            </div>
            <div class="timeline-card-detail">${detailText}</div>
            <div class="timeline-card-time">${timeStr}</div>
          </div>
        `;
      }).join("");
    }
  }


  // 9. Personal Best Records Grid (Cartridge Card style)
  const recordsGrid = document.getElementById("records-grid-v2");
  const activeRecordsCount = document.getElementById("active-records-count");
  
  if (recordsGrid) {
    const playableGames = games.filter(game => !game.comingSoon);
    const activeModes = playableGames.filter(game => (stats.gameCounts[game.slug] ?? 0) > 0);

    if (activeRecordsCount) {
      const activeCountVal = activeModes.length;
      activeRecordsCount.textContent = `${activeCountVal} ${activeCountVal === 1 ? 'Mode' : 'Modes'} Played`;
    }

    if (activeModes.length === 0) {
      recordsGrid.innerHTML = `
        <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-4) var(--space-2); color: var(--muted); font-size: 13px; font-weight: bold; text-transform: uppercase;">
          <p style="margin-bottom: var(--space-2);">No game records found</p>
          <a href="/" class="btn-action primary" style="display: inline-block; text-decoration: none; padding: 6px 16px;">Play Mode</a>
        </div>
      `;
      if (activeRecordsCount) activeRecordsCount.style.display = "none";
    } else {
      recordsGrid.innerHTML = activeModes.map(game => {
        const plays = stats.gameCounts[game.slug] ?? 0;
        const isScoreGame = game.engine === "falling-words" || game.engine === "grid-puzzle";
        
        let recordLabel = "⚡ Best Time";
        let recordValue = "--";
        
        if (isScoreGame) {
          recordLabel = "🏆 High Score";
          const score = stats.highScores[game.slug];
          recordValue = score !== undefined ? `${score} pts` : "--";
        } else {
          recordLabel = "⚡ Best Time";
          const time = stats.fastestSolves[game.slug];
          recordValue = time !== undefined ? `${time}s` : "--";
        }

        return `
          <div class="record-cartridge-card">
            <h4 class="cartridge-game-title">${game.name}</h4>
            <div class="cartridge-stats-stack">
              <div class="record-stat-line">
                <span>${isScoreGame ? '🏆' : '⚡'}</span>
                <strong class="highlight-val">${recordValue}</strong>
                <span style="font-size: 9px; color: var(--muted); text-transform: uppercase; font-weight: bold; margin-left: 2px;">${isScoreGame ? 'Score' : 'Time'}</span>
              </div>
              <div class="record-stat-line">
                <span>🎮</span>
                <strong>${plays}</strong>
                <span style="font-size: 9px; color: var(--muted); text-transform: uppercase; font-weight: bold; margin-left: 2px;">${plays === 1 ? 'Play' : 'Plays'}</span>
              </div>
            </div>
          </div>
        `;
      }).join("");
    }
  }


  // 10. Achievements Showcasing Grid
  const achGrid = document.getElementById("achievements-grid");
  const achUnlockedText = document.getElementById("ach-unlocked-text");
  const achPercentText = document.getElementById("ach-percent-text");
  const achProgressBar = document.getElementById("ach-progress-bar");

  if (achGrid) {
    const unlockedCount = achievements.filter(ach => ach.test(stats)).length;
    const totalCount = achievements.length;
    const unlockedPct = totalCount > 0 ? Math.round((unlockedCount / totalCount) * 100) : 0;

    if (achUnlockedText) achUnlockedText.textContent = `${unlockedCount} / ${totalCount} Unlocked`;
    if (achPercentText) achPercentText.textContent = `${unlockedPct}%`;
    if (achProgressBar) achProgressBar.style.width = `${unlockedPct}%`;

    function renderAchievementsGrid(filter: string) {
      if (!achGrid) return;
      
      const filtered = achievements.filter(ach => {
        const isUnlocked = ach.test(stats);
        if (filter === "unlocked") return isUnlocked;
        if (filter === "locked") return !isUnlocked;
        return true;
      });

      if (filtered.length === 0) {
        achGrid.innerHTML = `
          <div style="grid-column: 1 / -1; text-align: center; padding: var(--space-3); color: var(--muted); font-size: 13px; font-weight: bold; text-transform: uppercase;">
            No achievements found
          </div>
        `;
        return;
      }

      achGrid.innerHTML = filtered.map(ach => {
        const isUnlocked = ach.test(stats);
        const emoji = achievementEmojis[ach.id] || "🏆";
        
        // Progress tags or Unlocked status label
        let statusHtml = "";
        if (isUnlocked) {
          statusHtml = `<span class="badge-status-badge success">Unlocked</span>`;
        } else {
          // Calculate specific progress indicators if any
          if (ach.id === "three-wins") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.wins} / 3 Wins</span>`;
          } else if (ach.id === "ten-wins") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.wins} / 10 Wins</span>`;
          } else if (ach.id === "twenty-five-wins") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.wins} / 25 Wins</span>`;
          } else if (ach.id === "fifty-wins") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.wins} / 50 Wins</span>`;
          } else if (ach.id === "hundred-wins") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.wins} / 100 Wins</span>`;
          } else if (ach.id === "three-streak") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.longestStreak} / 3 Streak</span>`;
          } else if (ach.id === "seven-streak") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.longestStreak} / 7 Streak</span>`;
          } else if (ach.id === "thirty-streak") {
            statusHtml = `<span class="badge-status-badge progress-tag">${stats.longestStreak} / 30 Streak</span>`;
          } else {
            statusHtml = `<span class="badge-status-badge">Locked</span>`;
          }
        }

        return `
          <div class="collectible-badge-card ${isUnlocked ? "unlocked" : "locked"}">
            <div class="badge-header-row">
              <div class="badge-icon-wrap">
                ${isUnlocked ? emoji : "🔒"}
              </div>
              <div class="badge-title-group">
                <h4 class="badge-title" title="${ach.name}">${ach.name}</h4>
                ${statusHtml}
              </div>
            </div>
            <p class="badge-desc">${ach.description}</p>
          </div>
        `;
      }).join("");
    }

    renderAchievementsGrid("all");

    // Filter selector tabs
    const filterTabs = document.querySelectorAll(".filter-tab");
    filterTabs.forEach(tab => {
      tab.addEventListener("click", (e) => {
        filterTabs.forEach(t => t.classList.remove("active"));
        const target = e.currentTarget as HTMLButtonElement;
        target.classList.add("active");
        
        const filterVal = target.getAttribute("data-filter") || "all";
        renderAchievementsGrid(filterVal);
      });
    });
  }

  window.addEventListener("gamecompleted", () => {
    window.location.reload();
  });
</script>
