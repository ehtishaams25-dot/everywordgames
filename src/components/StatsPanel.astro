<!-- 
  =============================================================
  GAMING PROFILE DASHBOARD (REFINED HIERARCHY): StatsPanel.astro
  =============================================================
-->
<div class="profile-dashboard">
  
  <!-- ROW 1: HERO PROFILE HERO SECTION -->
  <section class="dashboard-hero-section glass-card" aria-label="Player Profile">
    <div class="hero-profile-container">
      
      <!-- Avatar with Glowing Level Badge & Interactive Selector -->
      <div class="avatar-interactive-wrapper">
        <button id="avatar-trigger-btn" class="avatar-glow-ring" title="Click to change avatar">
          <div class="avatar-emoji" id="display-avatar">👽</div>
          <div class="avatar-edit-badge">⚙️</div>
        </button>
        <div class="avatar-level-badge" id="profile-level-badge">LVL 1</div>
        
        <!-- Avatar Popover Dialog -->
        <div class="avatar-selector-popover hidden" id="avatar-popover">
          <div class="popover-header">
            <span>Choose Your Avatar</span>
            <button type="button" id="close-avatar-popover" class="close-btn">&times;</button>
          </div>
          <div class="avatar-options-grid" id="avatar-options">
            <!-- Dynamically populated options based on level -->
          </div>
          <div class="popover-tip">Level up to unlock new avatars!</div>
        </div>
      </div>
      
      <!-- Profile Information -->
      <div class="hero-details">
        <div class="player-name-wrapper">
          <div class="name-display-group" id="name-display-group">
            <h2 class="player-name" id="display-username">Player 1</h2>
            <button id="edit-name-btn" class="edit-icon-btn" title="Edit Name">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
              </svg>
            </button>
          </div>
          <div class="name-edit-group hidden" id="name-edit-group">
            <input type="text" id="username-input" class="username-input" maxlength="20" placeholder="Enter name..." />
            <button id="save-name-btn" class="btn-action primary">Save</button>
            <button id="cancel-name-btn" class="btn-action secondary">Cancel</button>
          </div>
        </div>
        
        <div class="player-rank" id="player-rank-title">Level 1 Novice</div>
        
        <!-- XP Progress Bar -->
        <div class="xp-progress-wrapper">
          <div class="xp-labels-row">
            <span class="xp-label-next" id="xp-level-target">XP to Level 2</span>
            <span class="xp-values" id="xp-progress-text">0 / 500 XP</span>
          </div>
          <div class="xp-bar-track">
            <div class="xp-bar-fill" id="xp-progress-bar">
              <div class="xp-bar-glow"></div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Streak and Reward Info -->
      <div class="hero-milestones">
        <div class="streak-mini-grid">
          <div class="streak-mini-card fire">
            <span class="emoji">🔥</span>
            <div class="text-group">
              <strong id="card-current-streak">0</strong>
              <span>Current Streak</span>
            </div>
          </div>
          <div class="streak-mini-card gold">
            <span class="emoji">🏆</span>
            <div class="text-group">
              <strong id="card-best-streak">0</strong>
              <span>Best Streak</span>
            </div>
          </div>
        </div>
        
        <div class="reward-unlock-card">
          <span class="reward-icon">🎁</span>
          <div class="reward-details">
            <span class="label">Next Unlockable Reward</span>
            <strong class="reward-name" id="next-reward-name">Robot Avatar</strong>
            <span class="reward-level" id="next-reward-requirement">Unlocks at Level 2</span>
          </div>
        </div>
      </div>
      
    </div>
  </section>

  <!-- ROW 2: MAIN GRID (LEFT: STATS & INSIGHTS, RIGHT: ACHIEVEMENTS & RECORDS) -->
  <div class="dashboard-main-grid">
    
    <!-- LEFT SIDE: STATISTICS & VISUAL INSIGHTS -->
    <div class="dashboard-left-column">
      
      <!-- Featured Highlight Statistics Grid -->
      <div class="stats-highlight-group">
        
        <!-- Featured Win Rate Card (Center Aligned, No Side Float) -->
        <div class="featured-stat-card glass-card hover-glow">
          <div class="win-rate-centered-layout">
            <div class="circular-chart-container">
              <svg viewBox="0 0 36 36" class="circular-chart lime-glow">
                <circle class="circle-bg" cx="18" cy="18" r="15.915" />
                <circle class="circle-fill" id="winrate-circle" cx="18" cy="18" r="15.915" transform="rotate(-90 18 18)" stroke-dasharray="0 100" />
                <text x="18" y="21" class="percentage" id="winrate-percent">0%</text>
              </svg>
            </div>
            <h3 class="win-rate-label">Win Rate</h3>
            <span class="win-rate-supporting" id="winrate-details">0 Wins • 0 Losses</span>
          </div>
        </div>
        
        <!-- Support Stat Cards (Follows Icon -> Value -> Label hierarchy) -->
        <div class="supporting-stats-grid">
          
          <!-- Card 1: Games Played -->
          <div class="stat-card-micro glass-card">
            <span class="card-icon">🎮</span>
            <strong class="card-primary-value" id="val-played">0</strong>
            <span class="card-label">Games Played</span>
            <span class="card-support-info">Lifetime</span>
          </div>
          
          <!-- Card 2: Current Streak -->
          <div class="stat-card-micro glass-card">
            <span class="card-icon">🔥</span>
            <strong class="card-primary-value" id="val-current-streak">0</strong>
            <span class="card-label">Current Streak</span>
            <span class="card-support-info" id="val-best-streak">Best: 0</span>
          </div>
          
          <!-- Card 3: Fastest Solve -->
          <div class="stat-card-micro glass-card">
            <span class="card-icon">⚡</span>
            <strong class="card-primary-value" id="val-fastest">--</strong>
            <span class="card-label">Fastest Solve</span>
            <span class="card-support-info" id="val-average">Average: --</span>
          </div>
          
          <!-- Card 4: Favorite Game -->
          <div class="stat-card-micro glass-card">
            <span class="card-icon">🏆</span>
            <strong class="card-primary-value truncate" id="val-favgame">None yet</strong>
            <span class="card-label">Favorite Mode</span>
            <span class="card-support-info" id="val-favgame-plays">0 Plays</span>
          </div>
          
        </div>
        
      </div>
      
      <!-- Progress & Split Insights Row (Win/Loss Card & Most Played Modes Card) -->
      <div class="insights-grid-row">
        
        <!-- Insight Card 1: Win/Loss Donut Chart -->
        <div class="insight-split-card glass-card">
          <h3 class="panel-section-title">📊 Win / Loss Ratio</h3>
          <div class="donut-chart-centered-wrapper">
            <div class="donut-chart-container">
              <svg viewBox="0 0 40 40" class="donut-chart">
                <circle class="donut-ring" cx="20" cy="20" r="15.915" />
                <circle class="donut-segment wins" id="donut-segment-wins" cx="20" cy="20" r="15.915" transform="rotate(-90 20 20)" stroke-dasharray="0 100" />
                <text x="20" y="21.5" class="donut-number" id="donut-wins-val">0</text>
                <text x="20" y="27.5" class="donut-label">WINS</text>
              </svg>
            </div>
            <div class="donut-ratio-breakdown" id="donut-ratio-details">
              0 Wins • 0 Losses
            </div>
          </div>
        </div>
        
        <!-- Insight Card 2: Most Played Modes -->
        <div class="insight-split-card glass-card">
          <h3 class="panel-section-title">🔥 Most Played Modes</h3>
          <div class="category-bars-list" id="category-bars">
            <!-- Dynamically populated progress bars -->
          </div>
        </div>
        
      </div>
      
      <!-- Recent Activity Timeline (Clean Timeline Cards) -->
      <div class="dashboard-timeline-card glass-card">
        <h3 class="panel-section-title">🕒 Recent Activity</h3>
        <div class="timeline-grid-wrapper" id="timeline-flow">
          <!-- Dynamically populated timeline cards -->
        </div>
      </div>

    </div>

    <!-- RIGHT SIDE: COLLECTIBLE ACHIEVEMENTS & PERSONAL BEST RECORDS -->
    <div class="dashboard-right-column">
      
      <!-- Personal Best Records (Cartridge Grid Layout) -->
      <div class="dashboard-records-card glass-card" id="personal-records-section">
        <div class="card-header-flex">
          <h3 class="panel-section-title">🏆 Personal Bests</h3>
          <span class="active-badge" id="active-records-count">0 Modes Played</span>
        </div>
        <div class="records-grid-v2" id="records-grid-v2">
          <!-- Dynamically populated cartridge cards -->
        </div>
      </div>
      
      <!-- Achievement System (Refined Card Layout) -->
      <div class="dashboard-achievements-card glass-card">
        <div class="achievements-header-wrapper">
          <h3 class="panel-section-title">👑 Achievements</h3>
          
          <div class="achievements-overall-stats">
            <div class="ach-progress-header">
              <span id="ach-unlocked-text">0 / 23 Unlocked</span>
              <span id="ach-percent-text">0%</span>
            </div>
            <div class="ach-progress-track">
              <div class="ach-progress-fill" id="ach-progress-bar"></div>
            </div>
          </div>
          
          <!-- Filter Tabs -->
          <div class="achievement-filters">
            <button class="filter-tab active" data-filter="all">All</button>
            <button class="filter-tab" data-filter="unlocked">Unlocked</button>
            <button class="filter-tab" data-filter="locked">Locked</button>
          </div>
        </div>
        
        <div class="achievements-showcase-grid" id="achievements-grid">
          <!-- Dynamically populated achievements -->
        </div>
      </div>

    </div>
    
  </div>
  
</div>

<style>
  /* Core Variables & Spacing Tokens (8px Grid System) */
  :root {
    --space-1: 8px;
    --space-2: 16px;
    --space-3: 24px;
    --space-4: 32px;
    --space-6: 48px;
    
    --dash-glow: 0 0 20px rgba(190, 255, 0, 0.15);
    --dash-border: rgba(190, 255, 0, 0.15);
    --dash-panel-bg: rgba(42, 46, 36, 0.4);
    --dash-accent: var(--lime, #BEFF00);
    --dash-accent-dim: var(--lime-dim, #9ACC00);
    --dash-card-bg: rgba(26, 28, 24, 0.75);
    --dash-card-bg-hover: rgba(35, 38, 32, 0.9);
  }

  [data-theme="light"] {
    --dash-glow: 0 0 15px rgba(255, 122, 0, 0.15);
    --dash-border: rgba(255, 122, 0, 0.15);
    --dash-panel-bg: rgba(244, 239, 230, 0.6);
    --dash-accent: var(--lime, #FF7A00);
    --dash-accent-dim: var(--lime-dim, #E86A00);
    --dash-card-bg: rgba(255, 255, 255, 0.85);
    --dash-card-bg-hover: rgba(244, 239, 230, 0.95);
  }

  /* Glassmorphism style panels */
  .glass-card {
    background: var(--dash-panel-bg);
    border: 1px solid var(--dash-border);
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    border-radius: var(--radius, 16px);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.25);
    padding: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .hover-glow {
    transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.2s ease;
  }
  .hover-glow:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 40px 0 rgba(0, 0, 0, 0.35), 0 0 15px var(--dash-border);
  }

  /* Profile layout grid */
  .profile-dashboard {
    width: 100%;
    margin-top: 1.5rem;
    color: var(--text);
  }

  .dashboard-main-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }

  @media (min-width: 1024px) {
    .dashboard-main-grid {
      grid-template-columns: 1.15fr 0.85fr;
      align-items: start;
    }
  }

  /* HERO SECTION */
  .dashboard-hero-section {
    padding: var(--space-3) var(--space-4);
  }

  .hero-profile-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero-profile-container {
      grid-template-columns: auto 1fr auto;
    }
  }

  /* Avatar selector */
  .avatar-interactive-wrapper {
    position: relative;
    justify-self: center;
    display: inline-block;
  }

  .avatar-glow-ring {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 104px;
    height: 104px;
    background: radial-gradient(circle, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.5) 100%);
    box-shadow: 0 0 15px var(--dash-border), inset 0 0 10px rgba(0,0,0,0.5);
    border: 3px solid var(--dash-accent);
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.15);
  }

  .avatar-glow-ring:hover {
    transform: scale(1.04);
    box-shadow: 0 0 20px var(--dash-accent), inset 0 0 12px rgba(0,0,0,0.6);
  }

  .avatar-emoji {
    font-size: 52px;
    line-height: 1;
    user-select: none;
  }

  .avatar-edit-badge {
    position: absolute;
    bottom: 2px;
    right: 2px;
    background: var(--dash-card-bg);
    border: 1px solid var(--dash-border);
    color: var(--text);
    font-size: 11px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .avatar-glow-ring:hover .avatar-edit-badge {
    opacity: 1;
  }

  .avatar-level-badge {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--dash-accent);
    color: var(--bg);
    font-family: "Bebas Neue", sans-serif;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 1px;
    padding: 2px 10px;
    border-radius: 12px;
    border: 2px solid var(--bg);
    box-shadow: 0 3px 8px rgba(0,0,0,0.3);
    white-space: nowrap;
  }

  [data-theme="dark"] .avatar-level-badge {
    color: #1A1C18;
  }

  .avatar-selector-popover {
    position: absolute;
    top: 114px;
    left: 50%;
    transform: translateX(-50%);
    width: 260px;
    background: var(--surface2, #33382D);
    border: 2px solid var(--dash-border);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    z-index: 50;
    padding: var(--space-2);
  }

  .avatar-selector-popover.hidden {
    display: none;
  }

  .popover-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-1);
    margin-bottom: var(--space-2);
    font-family: "Bebas Neue", sans-serif;
    letter-spacing: 0.5px;
    font-size: 15px;
  }

  .popover-header .close-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 20px;
    cursor: pointer;
    padding: 0;
  }

  .avatar-options-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-1);
  }

  .avatar-opt {
    background: var(--surface, #2A2E24);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 22px;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
    padding: 0;
  }

  .avatar-opt:not(.locked):hover {
    background: var(--dash-panel-bg);
    border-color: var(--dash-accent);
    transform: scale(1.08);
  }

  .avatar-opt.selected {
    border-color: var(--dash-accent);
    box-shadow: 0 0 8px var(--dash-border);
    background: rgba(190, 255, 0, 0.08);
  }

  .avatar-opt.locked {
    opacity: 0.3;
    cursor: not-allowed;
    background: var(--bg);
  }

  .avatar-opt.locked::after {
    content: "🔒";
    position: absolute;
    font-size: 8px;
    bottom: -2px;
    right: -2px;
  }

  .popover-tip {
    font-size: 10px;
    color: var(--muted);
    text-align: center;
    margin-top: var(--space-1);
  }

  /* Profile Details styling */
  .hero-details {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }

  @media (min-width: 768px) {
    .hero-details {
      text-align: left;
    }
  }

  .player-name-wrapper {
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .player-name-wrapper {
      justify-content: flex-start;
    }
  }

  .name-display-group {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .player-name {
    font-family: "Bebas Neue", sans-serif;
    font-size: 40px;
    letter-spacing: 1px;
    margin: 0;
    color: var(--text);
    line-height: 1;
    text-transform: uppercase;
  }

  .edit-icon-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 6px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .edit-icon-btn:hover {
    color: var(--dash-accent);
    background: rgba(190, 255, 0, 0.08);
  }

  .name-edit-group {
    display: flex;
    gap: var(--space-1);
    align-items: center;
    width: 100%;
    max-width: 300px;
  }

  .username-input {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 13px;
    font-weight: bold;
    outline: none;
  }

  .username-input:focus {
    border-color: var(--dash-accent);
    box-shadow: 0 0 6px rgba(190, 255, 0, 0.15);
  }

  .btn-action {
    font-family: "Bebas Neue", sans-serif;
    padding: 5px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    border: none;
  }

  .btn-action.primary {
    background: var(--dash-accent);
    color: var(--bg);
  }
  [data-theme="dark"] .btn-action.primary {
    color: #1A1C18;
  }

  .btn-action.secondary {
    background: var(--surface2);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .player-rank {
    font-family: "Bebas Neue", sans-serif;
    font-size: 18px;
    letter-spacing: 0.5px;
    color: var(--dash-accent);
    text-transform: uppercase;
  }

  .xp-progress-wrapper {
    margin-top: var(--space-2);
    width: 100%;
    max-width: 380px;
  }

  .xp-labels-row {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    font-weight: bold;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .xp-bar-track {
    background: var(--surface2, #33382D);
    height: 12px;
    border-radius: 6px;
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--border);
    position: relative;
  }

  .xp-bar-fill {
    height: 100%;
    width: 0%;
    border-radius: 6px;
    background: linear-gradient(90deg, var(--dash-accent-dim) 0%, var(--dash-accent) 100%);
    position: relative;
    transition: width 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .xp-bar-fill::after {
    content: "";
    position: absolute;
    top: 0; left: 0; bottom: 0; right: 0;
    background-image: linear-gradient(
      -45deg,
      rgba(255, 255, 255, 0.12) 25%,
      transparent 25%,
      transparent 50%,
      rgba(255, 255, 255, 0.12) 50%,
      rgba(255, 255, 255, 0.12) 75%,
      transparent 75%,
      transparent
    );
    background-size: 15px 15px;
    animation: bar-stripes-move 1.5s linear infinite;
  }

  .xp-bar-glow {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 6px;
    background: #fff;
    box-shadow: 0 0 8px #fff, 0 0 4px var(--dash-accent);
    opacity: 0.6;
  }

  /* Hero milestones styling */
  .hero-milestones {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
    max-width: 300px;
  }

  .streak-mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .streak-mini-card {
    background: var(--dash-card-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px;
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .streak-mini-card .emoji {
    font-size: 22px;
  }

  .streak-mini-card .text-group {
    display: flex;
    flex-direction: column;
  }

  .streak-mini-card .text-group strong {
    font-family: "Bebas Neue", sans-serif;
    font-size: 22px;
    line-height: 1.1;
  }

  .streak-mini-card .text-group span {
    font-size: 9px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: bold;
  }

  .streak-mini-card.fire {
    border-color: rgba(255, 122, 0, 0.25);
  }
  .streak-mini-card.fire strong {
    color: var(--v2-orange, #FF7A00);
  }

  .streak-mini-card.gold {
    border-color: rgba(245, 166, 35, 0.25);
  }
  .streak-mini-card.gold strong {
    color: #f5a623;
  }

  .reward-unlock-card {
    background: linear-gradient(135deg, rgba(190, 255, 0, 0.04) 0%, rgba(0,0,0,0.15) 100%);
    border: 1px solid var(--dash-border);
    border-radius: 10px;
    padding: 10px var(--space-2);
    display: flex;
    align-items: center;
