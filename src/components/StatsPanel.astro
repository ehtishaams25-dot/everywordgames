<div class="profile-strip" id="stats-panel">
  <div class="profile-avatar">👽</div>
  
  <div class="profile-main">
    <div class="profile-header">
      <h3 class="profile-name">Player 1</h3>
      <span class="profile-level" id="profile-level-badge">Level 1</span>
    </div>
    
    <div class="xp-track">
      <div class="xp-fill"></div>
    </div>
    
    <div class="profile-stats">
      <div class="profile-stat">
        <span class="p-stat-label">PLAYED</span>
        <strong class="p-stat-value" data-stat="played">0</strong>
      </div>
      <div class="profile-stat">
        <span class="p-stat-label">WINS</span>
        <strong class="p-stat-value" data-stat="wins">0</strong>
      </div>
      <div class="profile-stat">
        <span class="p-stat-label">WIN RATE</span>
        <strong class="p-stat-value" data-stat="winRate">0%</strong>
      </div>
      <div class="profile-stat">
        <span class="p-stat-label">STREAK</span>
        <strong class="p-stat-value streak-value" data-stat="currentStreak">0</strong>
      </div>
    </div>
  </div>
  
  <a class="btn-ghost btn-profile" href="/stats">View Full Profile &rarr;</a>
</div>

<style>
  .profile-strip {
    background: var(--surface);
    border-radius: 14px;
    padding: 24px 28px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 32px;
    align-items: center;
    border: 1px solid var(--border);
  }

  @media (max-width: 820px) {
    .profile-strip {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
    .profile-main {
      width: 100%;
    }
    .btn-profile {
      align-self: center !important;
    }
  }

  .profile-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--lime);
    display: grid;
    place-items: center;
    font-size: 24px;
  }

  .profile-main {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .profile-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  @media (max-width: 820px) {
    .profile-header {
      justify-content: center;
    }
  }

  .profile-name {
    font-family: "Bebas Neue", sans-serif;
    font-size: 28px;
    letter-spacing: 1px;
    margin: 0;
    line-height: 1;
  }

  .profile-level {
    background: rgba(190, 255, 0, 0.08);
    border: 1px solid rgba(190, 255, 0, 0.2);
    color: var(--lime);
    font-size: 12px;
    padding: 3px 9px;
    border-radius: 4px;
    font-weight: 600;
  }

  .profile-stats {
    display: flex;
    gap: 40px;
    margin-top: 4px;
  }

  @media (max-width: 820px) {
    .profile-stats {
      justify-content: center;
      gap: 20px;
      flex-wrap: wrap;
    }
  }

  .profile-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: flex-start;
  }

  @media (max-width: 820px) {
    .profile-stat {
      align-items: center;
    }
  }

  .p-stat-label {
    font-size: 11px;
    text-transform: uppercase;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .p-stat-value {
    font-family: "Bebas Neue", sans-serif;
    font-size: 26px;
    line-height: 1;
    font-weight: normal;
  }

  .streak-value {
    color: #FF7800;
  }

  .btn-profile {
    align-self: flex-start;
    color: var(--muted);
    border-color: rgba(255,255,255,0.1);
  }
  .btn-profile:hover {
    color: var(--text);
  }
</style>

<script>
  import { loadStats } from "@/engines/playerStore";
  const stats = loadStats();
  const winRate = stats.played ? Math.round((stats.wins / stats.played) * 100) : 0;
  const average = stats.wins ? Math.round(stats.totalSolveSeconds / stats.wins) : null;
  const values: Record<string, string | number> = {
    played: stats.played,
    wins: stats.wins,
    losses: stats.losses,
    winRate: `${winRate}%`,
    currentStreak: stats.currentStreak,
    longestStreak: stats.longestStreak,
    fastestSolve: stats.fastestSolve === null ? "-" : `${stats.fastestSolve}s`,
    averageSolve: average === null ? "-" : `${average}s`
  };
  Object.entries(values).forEach(([key, value]) => {
    const node = document.querySelector(`[data-stat="${key}"]`);
    if (node) node.textContent = String(value);
  });

  const xp = (stats.wins * 50) + (stats.played * 10);
  const level = Math.floor(xp / 500) + 1;
  const levelBadge = document.getElementById("profile-level-badge");
  if (levelBadge) {
    levelBadge.textContent = `Level ${level}`;
  }
  
  // Update XP fill track (assuming max 500 XP per level, so xp % 500 is progress)
  const xpFill = document.querySelector(".xp-fill") as HTMLElement;
  if (xpFill) {
    const progress = ((xp % 500) / 500) * 100;
    xpFill.style.width = `${progress}%`;
  }
</script>
