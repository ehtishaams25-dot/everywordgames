---
import type { GameConfig } from "@/data/games";
import { playableGames } from "@/data/games";

interface Props {
  game: GameConfig;
}

const { game } = Astro.props;
const relatedGames = playableGames
  .filter((item) => item.slug !== game.slug && (item.category === game.category || item.engine === game.engine))
  .slice(0, 4);
---

<section class="section game-section">
  <div class="container layout-split">

    <div class="game-stage" id="game-root" data-slug={game.slug}>
      <p class="muted" style="text-align: center;">Loading {game.name}...</p>
    </div>
  </div>
</section>

<script>
  import { mountGame } from "@/lib/gameApp";
  const root = document.querySelector<HTMLElement>("#game-root");
  if (root) mountGame(root);
</script>
